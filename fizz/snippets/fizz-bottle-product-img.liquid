{% comment %}
  Transparent bottle product PNG matched to lifestyle colorways.
  Usage: {% render 'fizz-bottle-product-img', color_slug: color_slug, alt: variant.title, class: 'fizz-product-pdp__img', width: 1200, height: 1400, loading: 'eager', id: 'fizz-bottle-image' %}
{% endcomment %}
{% liquid
  assign bottle_colors = 'arctic-white,charcoal-black,coral-orange,electric-blue,sage-green,steel-navy' | split: ','
  assign has_bottle_asset = false
  if color_slug != blank and bottle_colors contains color_slug
    assign has_bottle_asset = true
  endif
%}
{% if has_bottle_asset %}
  <img
    {% if id != blank %}id="{{ id }}"{% endif %}
    {% if main_image %}data-fizz-pdp-main-image{% endif %}
    src="{{ 'fizz-bottle-product-' | append: color_slug | append: '.png' | asset_url }}"
    alt="{{ alt | default: color_slug | escape }}"
    class="{{ class }}"
    loading="{{ loading | default: 'lazy' }}"
    width="{{ width | default: 800 }}"
    height="{{ height | default: 1100 }}"
  >
{% endif %}
