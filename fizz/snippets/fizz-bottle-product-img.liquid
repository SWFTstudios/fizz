{% comment %}
  Bottle product image — variant image, scene JPG, then transparent PNG fallback.
  Usage: {% render 'fizz-bottle-product-img', variant: variant, color_slug: color_slug, alt: variant.title, class: 'botimg', data_photo: true %}
{% endcomment %}
{% liquid
  assign variant_image = variant_image | default: variant.image
  assign bottle_colors = 'arctic-white,charcoal-black,coral-orange,electric-blue,sage-green,steel-navy' | split: ','
  assign has_bottle_asset = false
  if color_slug != blank and bottle_colors contains color_slug
    assign has_bottle_asset = true
  endif

  assign image_width = width | default: 1400
  assign image_src = ''

  if variant_image != blank
    assign image_src = variant_image | image_url: width: image_width
  elsif has_bottle_asset
    capture scene_url
      render 'fizz-bottle-scene-url', variant: variant, color_slug: color_slug, width: image_width
    endcapture
    assign scene_url = scene_url | strip
    if scene_url != blank
      assign image_src = scene_url
    else
      assign image_src = 'fizz-bottle-product-' | append: color_slug | append: '.png' | asset_url
    endif
  endif
%}
{% if image_src != blank %}
  <img
    {% if id != blank %}id="{{ id }}"{% endif %}
    {% if data_photo %}data-way-photo{% endif %}
    {% if main_image %}data-fizz-pdp-main-image{% endif %}
    src="{{ image_src }}"
    alt="{{ alt | default: color_slug | escape }}"
    class="{{ class }}{% if image_src contains 'fizz-bottle-scene-' %} botimg--scene{% endif %}"
    loading="{{ loading | default: 'lazy' }}"
    width="{{ width | default: 900 }}"
    height="{{ height | default: 1200 }}"
  >
{% endif %}
