{% comment %}
  Design tokens for the July 14 homepage template (suffix: july14).
  Uses sensible Lime Fizz defaults; section colors still override locally.
{% endcomment %}
<style>
  :root,
  .july14-template {
    --j14-paper: #f4f3ee;
    --j14-ink: #111214;
    --j14-accent: #c6f24e;
    --j14-surface: #e9e7df;
    --j14-dark: #0b0c0e;
    --j14-dark-text: #f2f1ea;
    --j14-ink-rgb: 17, 18, 20;
    --j14-paper-rgb: 244, 243, 238;
    --j14-font-heading: "Hanken Grotesk", system-ui, sans-serif;
    --j14-font-heading-weight: 700;
    --j14-font-body: "Hanken Grotesk", system-ui, sans-serif;
    --j14-font-body-weight: 400;
    --j14-heading-scale: 1;
    --j14-heading-transform: none;
    --j14-page-width: 1440px;
    --j14-gutter: 20px;
    --j14-btn-radius: 0px;
  }
</style>
