{% comment %}
  Fizz Claude product card.
  Usage:
    {% render 'fizz-product-card', product: product %}
    {% render 'fizz-product-card', product: product, variant: variant, badge: 'New' %}
{% endcomment %}
{% liquid
  assign use_variant = false
  if variant != blank
    assign use_variant = true
    assign card_variant = variant
  else
    assign card_variant = product.selected_or_first_available_variant
  endif

  assign card_title = product.title
  if use_variant and card_variant.title != 'Default Title'
    assign card_title = card_variant.title
  endif

  assign card_url = product.url
  if use_variant
    assign card_url = product.url | append: '?variant=' | append: card_variant.id
  endif

  assign card_price = card_variant.price
  assign card_image = card_variant.image | default: product.featured_image

  capture color_slug
    render 'fizz-color-slug', variant: card_variant
  endcapture
  assign color_slug = color_slug | strip

  assign bottle_colors = 'arctic-white,charcoal-black,coral-orange,electric-blue,sage-green,steel-navy' | split: ','
  assign is_bottle = false
  if bottle_colors contains color_slug
    assign is_bottle = true
  endif

  capture scene_raw
    render 'fizz-colorway-scene', slug: color_slug, variant: card_variant
  endcapture
  assign scene_parts = scene_raw | strip | split: '|'
  assign stage_bg = scene_parts[0]
  assign stage_bg_end = scene_parts[1]
  assign swatch_hex = scene_parts[4] | default: card_variant.metafields.custom.swatch_hex | default: '#1d2a44'
%}

<a href="{{ card_url }}" class="shop-card rv" data-hot>
  <div
    class="shop-card__stage"
    style="background:radial-gradient(ellipse 80% 90% at 50% 100%, {{ stage_bg_end | default: stage_bg }}, var(--color-surface));"
  >
    {% if badge != blank %}
      <span class="shop-card__badge">{{ badge }}</span>
    {% endif %}

    {% if is_bottle %}
      {% render 'fizz-bottle-product-img',
        variant: card_variant,
        color_slug: color_slug,
        alt: card_title,
        class: 'shop-card__bottle',
        loading: 'lazy',
        width: 140,
        height: 360
      %}
    {% elsif card_image %}
      {{ card_image | image_url: width: 600 | image_tag: class: 'shop-card__img', loading: 'lazy', alt: card_title }}
    {% endif %}
  </div>

  <div class="shop-card__body">
    <p class="shop-card__title">{{ card_title }}</p>
    <p class="shop-card__price">{{ card_price | money }}</p>

    {% unless use_variant %}
      {% if product.variants.size > 1 and is_bottle %}
        <div class="shop-card__swatches" aria-hidden="true">
          {% for v in product.variants limit: 6 %}
            {% capture slug %}
              {% render 'fizz-color-slug', variant: v %}
            {% endcapture %}
            {% assign slug = slug | strip %}
            {% if bottle_colors contains slug %}
              <span
                class="shop-card__sw"
                style="background:{{ v.metafields.custom.swatch_hex | default: '#1d2a44' }}"
              ></span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% endunless %}
  </div>
</a>
