[
  {
    "name": "theme_info",
    "theme_name": "Fizz Kinetic Spark",
    "theme_version": "0.1.0",
    "theme_author": "Fizz",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
