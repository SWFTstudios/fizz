  {
    "name": "Fizz Claude bubble animation",
    "settings": [
      {
        "type": "paragraph",
        "content": "Ambient rising bubbles in hero, how-it-works, footer, and PDP stage. See design/fizz-claude/README.md for per-section overrides."
      },
      {
        "type": "checkbox",
        "id": "fizz_claude_bubble_enabled",
        "label": "Enable ambient bubbles",
        "default": true
      },
      {
        "type": "select",
        "id": "fizz_claude_bubble_style",
        "label": "Bubble style",
        "options": [
          { "value": "ring", "label": "Ring — canvas outline only (lightweight)" },
          { "value": "glass", "label": "Glass — canvas bubbles with highlight (recommended)" },
          { "value": "bold", "label": "Bold — canvas bubbles, stronger fill" }
        ],
        "default": "glass"
      },
      {
        "type": "range",
        "id": "fizz_claude_bubble_peak_opacity",
        "min": 50,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "Animation peak opacity",
        "default": 92
      },
      {
        "type": "range",
        "id": "fizz_claude_bubble_size_scale",
        "min": 75,
        "max": 200,
        "step": 5,
        "unit": "%",
        "label": "Bubble size",
        "default": 125
      },
      {
        "type": "range",
        "id": "fizz_claude_bubble_count_scale",
        "min": 50,
        "max": 200,
        "step": 5,
        "unit": "%",
        "label": "Bubble density",
        "default": 110
      },
      {
        "type": "header",
