      },
      {
        "type": "range",
        "id": "fizz_claude_bubble_hero_alpha",
        "min": 10,
        "max": 80,
        "step": 1,
        "unit": "%",
        "label": "Hero & PDP alpha",
        "default": 70
      },
      {
        "type": "range",
        "id": "fizz_claude_bubble_how_alpha",
        "min": 10,
        "max": 80,
        "step": 1,
        "unit": "%",
        "label": "How it works alpha",
        "default": 55
