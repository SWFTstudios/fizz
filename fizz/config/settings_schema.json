  {
    "name": "Fizz Claude colorway design",
    "settings": [
      {
        "type": "header",
        "content": "Preset palette"
      },
      {
        "type": "select",
        "id": "fizz_claude_colorway_preset",
        "label": "Colorway preset",
        "options": [
          {
            "value": "lime_fizz",
            "label": "Lime Fizz"
          },
          {
            "value": "steel_navy",
            "label": "Steel Navy"
          },
          {
            "value": "citrus_burst",
            "label": "Citrus Burst"
          },
          {
            "value": "berry_night",
            "label": "Berry Night"
          },
          {
            "value": "electric_pool",
            "label": "Electric Pool"
          },
          {
            "value": "arctic_light",
            "label": "Arctic Light"
