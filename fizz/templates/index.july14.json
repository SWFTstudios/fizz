    "about": {
      "type": "july14-about",
      "blocks": {
        "m1": {
          "type": "milestone",
          "settings": {
            "year": "2023",
            "title": "The idea",
            "body": "<p>We got tired of buying sparkling water by the case.</p>"
          }
        },
        "m2": {
          "type": "milestone",
          "settings": {
            "year": "2024",
            "title": "First bottle",
            "body": "<p>Prototype carbonation that actually tastes great on the go.</p>"
          }
        },
        "m3": {
          "type": "milestone",
          "settings": {
            "year": "2025",
            "title": "Flavor packs",
            "body": "<p>Real fruit, zero sugar, electrolytes in every drop.</p>"
          }
        }
      },
      "block_order": ["m1", "m2", "m3"],
      "settings": {
        "eyebrow": "About us",
        "heading": "Bubbles without the baggage",
        "body": "<p>We started Fizz because sparkling water should not need a truck, a fridge, or a mountain of cans. One bottle, one pod, endless sparkle.</p>",
        "asset": "fizz-bottle-hero.jpg",
        "anchor_id": "about",
        "timeline_heading": "Our journey"
      }
    },
