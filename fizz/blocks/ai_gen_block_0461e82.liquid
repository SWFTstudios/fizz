{% doc %}
  @prompt
    Vertical parallax background media (video/image) scroll section, video upload option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-parallax-media-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    height: {{ block.settings.section_height }}px;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-parallax-media__container-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 150%;
    will-change: transform;
  }

  .ai-parallax-media__video-{{ ai_gen_id }},
  .ai-parallax-media__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-parallax-media__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-parallax-media__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-parallax-media__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-parallax-media__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
    z-index: 1;
  }

  .ai-parallax-media__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    text-align: center;
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 800px;
  }

  .ai-parallax-media__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-parallax-media__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-parallax-media-{{ ai_gen_id }} {
      height: {{ block.settings.section_height | times: 0.6 }}px;
    }

    .ai-parallax-media__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-parallax-media__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<parallax-media-{{ ai_gen_id }}
  class="ai-parallax-media-{{ ai_gen_id }}"
  data-speed="{{ block.settings.parallax_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-parallax-media__container-{{ ai_gen_id }}">
    {% if block.settings.media_type == 'video' %}
      {% if block.settings.video_shopify != blank %}
        {{ block.settings.video_shopify | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'ai-parallax-media__video-' | append: ai_gen_id }}
      {% elsif block.settings.video_url != blank %}
        <video
          class="ai-parallax-media__video-{{ ai_gen_id }}"
          autoplay
          muted
          loop
          playsinline
          src="{{ block.settings.video_url }}"
        >
        </video>
      {% else %}
        <div class="ai-parallax-media__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-parallax-media__empty-state-{{ ai_gen_id }}">
            Next, add a video
          </div>
        </div>
      {% endif %}
    {% elsif block.settings.media_type == 'image' and block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        class="ai-parallax-media__image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-parallax-media__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-parallax-media__empty-state-{{ ai_gen_id }}">
          Next, add an image or video
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-parallax-media__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  {% if block.settings.heading != blank or block.settings.text != blank %}
    <div class="ai-parallax-media__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-parallax-media__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-parallax-media__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  {% endif %}
</parallax-media-{{ ai_gen_id }}>

<script>
  (function() {
    class ParallaxMedia{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.container = this.querySelector('.ai-parallax-media__container-{{ ai_gen_id }}');
        this.speed = parseFloat(this.dataset.speed) || 0.5;
        this.ticking = false;
      }

      connectedCallback() {
        this.handleScroll = this.handleScroll.bind(this);
        this.updateParallax = this.updateParallax.bind(this);
        window.addEventListener('scroll', this.handleScroll, { passive: true });
        this.updateParallax();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      handleScroll() {
        if (!this.ticking) {
          window.requestAnimationFrame(() => {
            this.updateParallax();
            this.ticking = false;
          });
          this.ticking = true;
        }
      }

      updateParallax() {
        const rect = this.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        if (rect.top < windowHeight && rect.bottom > 0) {
          const scrolled = windowHeight - rect.top;
          const parallaxValue = scrolled * this.speed;
          this.container.style.transform = `translateY(-${parallaxValue}px)`;
        }
      }
    }

    customElements.define('parallax-media-{{ ai_gen_id }}', ParallaxMedia{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Parallax media",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video_shopify",
      "label": "Video upload"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "range",
      "id": "parallax_speed",
      "label": "Parallax speed",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Parallax scroll effect</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Experience smooth vertical parallax scrolling</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Parallax media"
    }
  ]
}
{% endschema %}
