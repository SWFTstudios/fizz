{% render 'fizz-section-spacing', section: section %}

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden ks-reveal opacity-0 translate-y-10 transition-all duration-1000" data-ks-hero-slideshow>
  <div class="absolute inset-0 w-full h-full ks-hero-slideshow__bg" data-ks-hero-viewport>
    <div class="ks-hero-slideshow__track" data-ks-hero-track>
      {% for block in section.blocks %}
        <div
          class="hero-slide ks-hero-slideshow__slide{% if forloop.first %} active{% endif %}"
          style="background-image: url('{% if block.settings.image %}{{ block.settings.image | image_url: width: 2000 }}{% else %}{{ block.settings.fallback_image | prepend: 'stitch-' | append: '.jpg' | asset_url }}{% endif %}');"
          {{ block.shopify_attributes }}
        ></div>
      {% endfor %}
    </div>
    <div class="absolute inset-0 bg-background/40 backdrop-blur-sm pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent pointer-events-none"></div>
  </div>
  <div class="relative z-10 text-center px-margin-mobile md:px-margin-desktop max-w-max-width mx-auto flex flex-col items-center">
    <h1 class="font-display-xl text-headline-lg-mobile md:text-display-xl text-on-surface mb-6 drop-shadow-2xl">{{ section.settings.heading }}</h1>
    <p class="font-body-md text-headline-lg-mobile md:text-headline-lg text-on-surface-variant max-w-3xl mb-12">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_url | default: routes.all_products_collection_url }}">
      {% render 'ks-button', label: section.settings.button_label, variant: 'ghost', tag: 'span' %}
    </a>
  </div>
</section>

{% stylesheet %}
  .ks-hero-slideshow__bg {
    overflow: hidden;
    touch-action: pan-y;
  }

  .ks-hero-slideshow__track {
    display: flex;
    height: 100%;
    will-change: transform;
  }

  .ks-hero-slideshow__slide {
    flex: 0 0 100%;
    min-width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }

  .fizz-swipe-viewport {
    touch-action: pan-y;
    cursor: grab;
  }

  .fizz-swipe-viewport.is-grabbing {
    cursor: grabbing;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "KS Hero Slideshow",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "hero"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
        { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Elevate Every Drop." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Your daily rituals, now with a sparkling twist. No Cords. No Counters. No Limits." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Systems" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback asset name", "default": "hero-slideshow-1" }
      ]
    }
  ],
  "presets": [
    {
      "name": "KS Hero Slideshow",
      "blocks": [
        { "type": "slide", "settings": { "fallback_image": "hero-slideshow-1" } },
        { "type": "slide", "settings": { "fallback_image": "hero-slideshow-2" } },
        { "type": "slide", "settings": { "fallback_image": "hero-slideshow-3" } }
      ]
    }
  ]
}
{% endschema %}
