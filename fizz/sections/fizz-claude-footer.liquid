<div class="foot rv" data-screen-label="Footer" style="background:var(--footer-bg);color:var(--footer-text)">
  {% render 'fizz-claude-bubbles',
    settings: section.settings,
    color_var: 'var(--footer-bubble-color)',
    seed: 41,
    rise: 700,
    default_count: 10
  %}
  <h2 class="fh">{{ section.settings.line_1 }}<br><span class="out2">{{ section.settings.line_2 }}</span></h2>
  <a class="bigcta" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" data-bub-ignore>{{ section.settings.cta_label }}</a>
  <div class="footmeta">
    <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
    <span>{{ section.settings.shipping_note }}</span>
    <span>{{ section.settings.guarantee_note }}</span>
    <span>
      {% if section.settings.instagram_url != blank %}<a href="{{ section.settings.instagram_url }}">Instagram</a>{% endif %}
      {% if section.settings.tiktok_url != blank %} / <a href="{{ section.settings.tiktok_url }}">TikTok</a>{% endif %}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "line_1", "label": "Line 1", "default": "Hydrate" },
    { "type": "text", "id": "line_2", "label": "Line 2 (outlined)", "default": "louder." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop FIZZ — $89" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "text", "id": "shipping_note", "label": "Shipping note", "default": "Free shipping over $50" },
    { "type": "text", "id": "guarantee_note", "label": "Guarantee note", "default": "30-day fizz guarantee" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },

    { "type": "header", "content": "Bubbles" },
    {
      "type": "checkbox",
      "id": "bubbles_enabled",
      "label": "Enable bubble animation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "bubble_use_theme",
      "label": "Use theme bubble defaults",
      "default": true,
      "info": "Turn off to set count, size, style, and color for this section only.",
      "visible_if": "{{ section.settings.bubbles_enabled }}"
    },
    {
      "type": "range",
      "id": "bubble_count",
      "label": "Ambient bubble count",
      "min": 4,
      "max": 40,
      "step": 1,
      "default": 10,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "range",
      "id": "bubble_size_scale",
      "label": "Bubble size",
      "min": 50,
      "max": 200,
      "step": 5,
      "unit": "%",
      "default": 115,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "select",
      "id": "bubble_style",
      "label": "Bubble style",
      "default": "glass",
      "options": [
        { "value": "ring", "label": "Ring" },
        { "value": "glass", "label": "Glass" },
        { "value": "bold", "label": "Bold" }
      ],
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "color",
      "id": "bubble_color",
      "label": "Bubble color",
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "range",
      "id": "bubble_peak_opacity",
      "label": "Bubble opacity",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 88,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "checkbox",
      "id": "bubble_wobble",
      "label": "Wobble drift",
      "default": false,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "select",
      "id": "bubble_interaction",
      "label": "User interaction",
      "default": "tap",
      "options": [
        { "value": "off", "label": "Off" },
        { "value": "tap", "label": "Tap area" },
        { "value": "button", "label": "Generator button" },
        { "value": "both", "label": "Tap area + button" }
      ],
      "visible_if": "{{ section.settings.bubbles_enabled }}"
    },
    {
      "type": "range",
      "id": "bubble_burst_count",
      "label": "Bubbles per tap",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 10,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction != 'off' }}"
    },
    {
      "type": "range",
      "id": "bubble_max_particles",
      "label": "Max particles",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 48,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction != 'off' }}"
    },
    {
      "type": "text",
      "id": "bubble_button_label",
      "label": "Generator button label",
      "default": "Pop bubbles",
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction == 'button' or section.settings.bubbles_enabled and section.settings.bubble_interaction == 'both' }}"
    },
    {
      "type": "select",
      "id": "bubble_button_position",
      "label": "Generator button position",
      "default": "bottom-left",
      "options": [
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "top-right", "label": "Top right" }
      ],
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction == 'button' or section.settings.bubbles_enabled and section.settings.bubble_interaction == 'both' }}"
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
