            "row_span": 2,
            "badge": "Evening",
            "title": "After Hours",
            "body": "Sleek finish for dinner parties and nightcaps.",
            "show_button": true,
            "button_style": "link",
            "link_mode": "bottle_variant"
          }
        },
        {
          "type": "lifestyle_card",
          "settings": {
            "color_slug": "sage-green",
            "col_span": 4,
            "row_span": 1,
            "badge": "Kitchen",
            "title": "Calm Kitchen",
            "body": "Soft, natural tones for everyday hydration.",
            "show_button": true,
            "button_style": "link",
            "link_mode": "bottle_variant"
          }
        },
        {
          "type": "lifestyle_card",
          "settings": {
            "color_slug": "steel-navy",
            "col_span": 4,
            "row_span": 1,
            "badge": "Work",
            "title": "Creative Desk",
            "body": "Focused fizz between meetings and deep work.",
            "show_button": true,
            "button_style": "link",
            "link_mode": "bottle_variant"
          }
        },
        {
          "type": "lifestyle_card",
          "settings": {
            "color_slug": "arctic-white",
            "col_span": 4,
            "row_span": 1,
            "badge": "Poolside",
            "title": "Poolside",
            "body": "Clean and crisp for sunny afternoons.",
            "show_button": true,
            "button_style": "link",
            "link_mode": "bottle_variant"
          }
        },
        {
          "type": "lifestyle_card",
          "settings": {
            "color_slug": "electric-blue",
            "col_span": 8,
            "row_span": 1,
            "badge": "Adventure",
            "title": "Outdoors",
            "body": "Bold color for hikes, trails, and weekend escapes.",
            "show_button": true,
            "button_style": "link",
            "link_mode": "bottle_variant"
          }
        }
      ]
    }
  ]
}
{% endschema %}
