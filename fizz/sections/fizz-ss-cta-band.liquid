{% render 'fizz-section-spacing', section: section %}

<section class="ss-section" aria-label="{{ section.settings.heading | escape }}">
  <div class="ss-container">
    <div class="ss-cta-band{% if section.settings.style == 'accent' %} ss-cta-band--accent{% endif %}">
      <div>
        <h2 class="ss-h2" data-ss-trigger="scroll" data-ss-split="words" data-ss-duration="0.35">
          {{ section.settings.heading }}
        </h2>
        {% if section.settings.body != blank %}
          <p class="ss-body" style="margin-top: 1rem;" data-ss-trigger="scroll" data-ss-fade="up">{{ section.settings.body }}</p>
        {% endif %}
      </div>
      <div data-ss-trigger="scroll" data-ss-fade="up">
        {% if section.settings.cta_label != blank %}
          <a
            class="ss-btn {% if section.settings.style == 'accent' %}ss-btn--dark{% else %}ss-btn--primary{% endif %}"
            href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
          >
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SS CTA band",
  "tag": "section",
  "class": "fizz-ss-cta-band fizz-section--spaced fizz-section--relaxed",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Delicious fizz made for everyday" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Crafted for busy days and slow moments alike." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Learn more" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "dark", "label": "Dark panel" },
        { "value": "accent", "label": "Accent coral" }
      ],
      "default": "accent"
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" }
      ],
      "default": "relaxed"
    },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "SS CTA band" }]
}
{% endschema %}
