{% render 'fizz-section-spacing', section: section %}

<section class="fizz-pdp-how" aria-label="{{ section.settings.eyebrow | escape }}">
  <div class="fizz-pdp-how__inner">
    <p class="fizz-pdp-how__eyebrow">{{ section.settings.eyebrow }}</p>
    <ol class="fizz-pdp-how__steps">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <li class="fizz-pdp-how__step" {{ block.shopify_attributes }}>
            <div class="fizz-pdp-how__step-icon" aria-hidden="true">{{ forloop.index }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.body }}</p>
          </li>
        {% endif %}
      {% endfor %}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "PDP how it works",
  "tag": "section",
  "class": "fizz-pdp-how-section fizz-section--spaced fizz-section--relaxed",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "relaxed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
                { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it works" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Fill" },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Fill the Fizz bottle with cold water up to the marked line."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP how it works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Fill",
            "body": "Fill the Fizz bottle with cold water up to the marked line."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Carbonate",
            "body": "Insert a Fizz Charge cartridge and press until you hear a crisp hiss."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Enjoy",
            "body": "Twist open and add flavor drops for the crispest sparkling water anywhere."
          }
        }
      ]
    }
  ]
}
{% endschema %}
