    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "range",
      "id": "parallax_speed",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Parallax speed",
      "default": 0.5,
      "info": "How much the background moves while scrolling. 0 disables movement."
