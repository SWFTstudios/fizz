<section class="j14-about" id="{{ section.settings.anchor_id | default: 'about' }}">
  <div class="j14-about__story">
    <div class="j14-about__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="j14-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="j14-heading j14-about__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="j14-about__body">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a class="j14-btn" href="{{ section.settings.cta_url | default: routes.root_url }}">
          {{- section.settings.cta_label | escape -}}
        </a>
      {%- endif -%}
    </div>
    <div class="j14-about__media">
      {%- render 'july14-media',
        video: section.settings.video,
        image: section.settings.image,
        asset: section.settings.asset,
        alt: section.settings.heading,
        class: 'j14-about__img',
        sizes: '(min-width: 750px) 45vw, 100vw'
      -%}
    </div>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="j14-about__milestones" style="margin-top: 3rem;">
      {%- if section.settings.timeline_heading != blank -%}
        <h3 class="j14-heading" style="margin-bottom: 1.5rem;">{{ section.settings.timeline_heading | escape }}</h3>
      {%- endif -%}
      <ul class="j14-sustain__grid">
        {%- for block in section.blocks -%}
          <li class="j14-sustain__item" {{ block.shopify_attributes }}>
            {%- if block.settings.year != blank -%}
              <span class="j14-sustain__stat">{{ block.settings.year | escape }}</span>
            {%- endif -%}
            <h4 class="j14-sustain__title">{{ block.settings.title | escape }}</h4>
            {%- if block.settings.body != blank -%}
              <div class="j14-sustain__text">{{ block.settings.body }}</div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "July14 About",
  "tag": "section",
  "class": "july14-about-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bubbles without the baggage"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>We started Fizz because sparkling water should not need a truck, a fridge, or a mountain of cans. One bottle, one pod, endless sparkle.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Overrides the image. Autoplays muted."
    },
    {
      "type": "text",
      "id": "asset",
      "label": "Theme asset fallback",
      "default": "fizz-bottle-hero.jpg"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "about"
    },
    {
      "type": "text",
      "id": "timeline_heading",
      "label": "Milestones heading",
      "default": "Our journey"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2024"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "First spark"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "July14 About",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "year": "2023",
            "title": "The idea",
            "body": "<p>We got tired of buying sparkling water by the case.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2024",
            "title": "First bottle",
            "body": "<p>Prototype carbonation that actually tastes great on the go.</p>"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "year": "2025",
            "title": "Flavor packs",
            "body": "<p>Real fruit, zero sugar, electrolytes in every drop.</p>"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index", "page"]
  }
}
{% endschema %}
