{% render 'fizz-section-spacing', section: section %}

<section class="ss-section ss-intro-split" aria-label="Intro">
  <div class="ss-container">
    <div class="ss-intro-split__title">
      {% if section.settings.title_line_1 != blank %}
        <h2 class="ss-h2" data-ss-trigger="scroll" data-ss-split="words" data-ss-duration="0.35">{{ section.settings.title_line_1 }}</h2>
      {% endif %}
      {% if section.settings.title_line_2 != blank %}
        <h2 class="ss-h2" data-ss-trigger="scroll" data-ss-split="words" data-ss-duration="0.35">{{ section.settings.title_line_2 }}</h2>
      {% endif %}
    </div>
    <div class="ss-intro-split__row">
      <div>
        {% if section.settings.heading != blank %}
          <h3 class="ss-h3" data-ss-trigger="scroll" data-ss-split="words" data-ss-duration="0.3" style="margin-bottom: 1rem;">{{ section.settings.heading }}</h3>
        {% endif %}
        {% if section.settings.body != blank %}
          <p class="ss-body" data-ss-trigger="scroll" data-ss-fade="up">{{ section.settings.body }}</p>
        {% endif %}
        {% if section.settings.cta_label != blank %}
          <p style="margin-top: 1.5rem;" data-ss-trigger="scroll" data-ss-fade="up">
            <a class="ss-link" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }}</a>
          </p>
        {% endif %}
      </div>
      <div data-ss-trigger="scroll" data-ss-fade="up">
        {% if section.settings.image != blank %}
          <div style="border-radius: var(--ss-radius); overflow: hidden; aspect-ratio: 4/5; background: var(--ss-elevated);">
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
          </div>
        {% elsif section.settings.side_body != blank %}
          <p class="ss-body">{{ section.settings.side_body }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SS Intro split",
  "tag": "section",
  "class": "fizz-ss-intro-split fizz-section--spaced fizz-section--statement",
  "settings": [
    { "type": "text", "id": "title_line_1", "label": "Title line 1", "default": "Sparkling water" },
    { "type": "text", "id": "title_line_2", "label": "Title line 2", "default": "without any compromise." },
    { "type": "text", "id": "heading", "label": "Subheading", "default": "Carbonation made the right way" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Fizz is a portable carbonation bottle paired with our in-house flavor packs so you can liven up your water in seconds—anytime, anywhere." },
    { "type": "textarea", "id": "side_body", "label": "Side column text (if no image)" },
    { "type": "image_picker", "id": "image", "label": "Side image" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Learn more" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "default", "label": "Default" }
      ],
      "default": "statement"
    },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "SS Intro split" }]
}
{% endschema %}
