{% render 'fizz-section-spacing', section: section %}
{{ 'fizz-lifestyle-gallery.css' | asset_url | stylesheet_tag }}

{% liquid
  assign hero_fallback = section.settings.hero_fallback | default: 'fizz-lifestyle-gallery-hero'
  assign thumb_blocks = section.blocks | where: 'type', 'thumbnail'
  assign gallery_blocks = section.blocks | where: 'type', 'gallery_row'
%}

<section class="fizz-lifestyle-gallery" data-fizz-lifestyle-gallery aria-label="{{ section.settings.heading | escape }}">
  <div class="fizz-lifestyle-gallery__hero">
    <div class="fizz-lifestyle-gallery__hero-media" data-fizz-lifestyle-hero-media>
      {% if section.settings.hero_image %}
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag: loading: 'eager', alt: section.settings.heading, data-fizz-lifestyle-hero-img: '' }}
      {% else %}
        <img
          src="{{ hero_fallback | append: '.jpg' | asset_url }}"
          alt="{{ section.settings.heading | escape }}"
          width="2400"
          height="1600"
          loading="eager"
          data-fizz-lifestyle-hero-img
        >
      {% endif %}
    </div>
    <div class="fizz-lifestyle-gallery__hero-overlay" aria-hidden="true"></div>
    <div class="fizz-lifestyle-gallery__hero-content">
      {% if section.settings.eyebrow != blank %}
        <p class="fizz-lifestyle-gallery__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="fizz-lifestyle-gallery__hero-title">{{ section.settings.heading }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="fizz-lifestyle-gallery__hero-lead">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.hero_cta_label != blank %}
        <a href="{{ section.settings.hero_cta_url | default: routes.all_products_collection_url }}" class="fizz-lifestyle-gallery__hero-cta">
          {{ section.settings.hero_cta_label }}
        </a>
      {% endif %}
    </div>
  </div>

  {% if thumb_blocks.size > 0 %}
    <div class="fizz-lifestyle-gallery__thumbs" data-fizz-lifestyle-thumbs>
      {% for block in thumb_blocks %}
        {% liquid
          assign thumb_src = block.settings.fallback_image | default: 'fizz-lifestyle-gallery-poolside' | append: '.jpg' | asset_url
          if block.settings.image
            assign thumb_src = block.settings.image | image_url: width: 400
          endif
        %}
        <button
          type="button"
          class="fizz-lifestyle-gallery__thumb{% if forloop.first %} is-active{% endif %}"
          data-fizz-lifestyle-thumb
          data-image-src="{% if block.settings.image %}{{ block.settings.image | image_url: width: 2400 }}{% else %}{{ block.settings.fallback_image | default: 'fizz-lifestyle-gallery-poolside' | append: '.jpg' | asset_url }}{% endif %}"
          aria-label="{{ block.settings.alt | default: 'View image' | escape }}"
          {{ block.shopify_attributes }}
        >
          <img src="{{ thumb_src }}" alt="" width="176" height="128" loading="lazy">
        </button>
      {% endfor %}
    </div>
  {% endif %}

  {% if section.settings.mission_text != blank %}
    <div class="fizz-lifestyle-gallery__mission">
      <div class="fizz-lifestyle-gallery__mission-inner">
        <p class="fizz-lifestyle-gallery__mission-text">{{ section.settings.mission_text }}</p>
        <div class="fizz-lifestyle-gallery__mission-nav" aria-hidden="true">
          <button type="button" tabindex="-1">←</button>
          <button type="button" tabindex="-1">→</button>
        </div>
      </div>
    </div>
  {% endif %}

  {% if gallery_blocks.size > 0 %}
    <div class="fizz-lifestyle-gallery__collection">
      <div class="fizz-lifestyle-gallery__collection-header">
        <h2 class="fizz-lifestyle-gallery__collection-title">{{ section.settings.collection_heading | default: 'Photoshoot collection' }}</h2>
        {% if section.settings.show_filters %}
          <div class="fizz-lifestyle-gallery__filters" aria-hidden="true">
            <span class="fizz-lifestyle-gallery__filter">All</span>
            <span class="fizz-lifestyle-gallery__filter">Ritual</span>
            <span class="fizz-lifestyle-gallery__filter">Outdoor</span>
            <span class="fizz-lifestyle-gallery__filter">Studio</span>
          </div>
        {% endif %}
      </div>

      <div class="fizz-lifestyle-gallery__rows">
        {% for block in gallery_blocks %}
          {% liquid
            assign layout_class = 'fizz-lifestyle-gallery__row-images'
            case block.settings.image_layout
              when 'duo'
                assign layout_class = layout_class | append: ' fizz-lifestyle-gallery__row-images--duo'
              when 'single'
                assign layout_class = layout_class | append: ' fizz-lifestyle-gallery__row-images--single'
            endcase
          %}
          <article class="fizz-lifestyle-gallery__row" {{ block.shopify_attributes }}>
            <div class="fizz-lifestyle-gallery__row-meta">
              {% if block.settings.label != blank %}
                <p class="fizz-lifestyle-gallery__row-label">{{ block.settings.label }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <h3 class="fizz-lifestyle-gallery__row-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.body != blank %}
                <p class="fizz-lifestyle-gallery__row-body">{{ block.settings.body }}</p>
              {% endif %}
              {% if block.settings.link_label != blank %}
                <a href="{{ block.settings.link_url | default: '#' }}" class="fizz-lifestyle-gallery__row-link">{{ block.settings.link_label }}</a>
              {% endif %}
            </div>
            <div class="{{ layout_class }}">
              {% for i in (1..3) %}
                {% liquid
                  assign image_key = 'image_' | append: i
                  assign fallback_key = 'fallback_' | append: i
                  assign row_image = block.settings[image_key]
                  assign row_fallback = block.settings[fallback_key]
                  if row_fallback == blank
                    case i
                      when 1
                        assign row_fallback = 'fizz-lifestyle-gallery-poolside'
                      when 2
                        assign row_fallback = 'fizz-lifestyle-gallery-commute'
                      else
                        assign row_fallback = 'fizz-lifestyle-gallery-outdoor'
                    endcase
                  endif
                %}
                {% if block.settings.image_layout == 'single' and i > 1 %}
                  {% break %}
                {% endif %}
                {% if block.settings.image_layout == 'duo' and i > 2 %}
                  {% break %}
                {% endif %}
                <div class="fizz-lifestyle-gallery__row-image">
                  {% if row_image %}
                    {{ row_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
                  {% else %}
                    <img
                      src="{{ row_fallback | append: '.jpg' | asset_url }}"
                      alt="{{ block.settings.title | escape }}"
                      width="1200"
                      height="1600"
                      loading="lazy"
                    >
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if section.settings.show_subscribe %}
    <div class="fizz-lifestyle-gallery__subscribe">
      <div class="fizz-lifestyle-gallery__subscribe-copy">
        <h2 class="fizz-lifestyle-gallery__subscribe-title">{{ section.settings.subscribe_heading }}</h2>
        {% form 'customer', class: 'fizz-lifestyle-gallery__subscribe-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.subscribe_placeholder }}" required autocomplete="email">
          <button type="submit">{{ section.settings.subscribe_button }}</button>
        {% endform %}
      </div>
      <div class="fizz-lifestyle-gallery__subscribe-media">
        {% if section.settings.subscribe_image %}
          {{ section.settings.subscribe_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: '' }}
        {% else %}
          <img
            src="{{ section.settings.subscribe_fallback | default: 'fizz-lifestyle-gallery-social' | append: '.jpg' | asset_url }}"
            alt=""
            width="1200"
            height="1600"
            loading="lazy"
          >
        {% endif %}
      </div>
    </div>
  {% endif %}
</section>

<script>
  (function () {
    var root = document.querySelector('[data-fizz-lifestyle-gallery]');
    if (!root) return;
    var heroImg = root.querySelector('[data-fizz-lifestyle-hero-img]');
    root.querySelectorAll('[data-fizz-lifestyle-thumb]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var src = btn.getAttribute('data-image-src');
        if (!src || !heroImg) return;
        heroImg.src = src;
        root.querySelectorAll('[data-fizz-lifestyle-thumb]').forEach(function (el) {
          el.classList.remove('is-active');
        });
        btn.classList.add('is-active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Fizz lifestyle gallery",
  "tag": "section",
  "class": "fizz-lifestyle-gallery-section fizz-section--spaced fizz-section--flush",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "relaxed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
        { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lifestyle" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sparkle with obsession" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Moments from the Fizz community — rituals, travel, and everyday hydration elevated." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_fallback", "label": "Hero fallback asset", "default": "fizz-lifestyle-gallery-hero", "info": "Theme asset filename without extension" },
    { "type": "text", "id": "hero_cta_label", "label": "Hero CTA label", "default": "See more" },
    { "type": "url", "id": "hero_cta_url", "label": "Hero CTA URL" },
    { "type": "header", "content": "Mission band" },
    { "type": "textarea", "id": "mission_text", "label": "Mission text", "default": "We inspire, engage, and challenge creative excellence in contemporary hydration culture, and beyond." },
    { "type": "header", "content": "Gallery" },
    { "type": "text", "id": "collection_heading", "label": "Collection heading", "default": "Photoshoot collection" },
    { "type": "checkbox", "id": "show_filters", "label": "Show decorative filters", "default": true },
    { "type": "header", "content": "Subscribe band" },
    { "type": "checkbox", "id": "show_subscribe", "label": "Show subscribe band", "default": true },
    { "type": "text", "id": "subscribe_heading", "label": "Subscribe heading", "default": "Subscribe now" },
    { "type": "text", "id": "subscribe_placeholder", "label": "Email placeholder", "default": "Email address" },
    { "type": "text", "id": "subscribe_button", "label": "Subscribe button", "default": "Subscribe" },
    { "type": "image_picker", "id": "subscribe_image", "label": "Subscribe image" },
    { "type": "text", "id": "subscribe_fallback", "label": "Subscribe fallback asset", "default": "fizz-lifestyle-gallery-social" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "thumbnail",
      "name": "Hero thumbnail",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback asset", "default": "fizz-lifestyle-gallery-poolside" },
        { "type": "text", "id": "alt", "label": "Accessible label", "default": "Gallery preview" }
      ]
    },
    {
      "type": "gallery_row",
      "name": "Gallery row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Behind the scenes" },
        { "type": "text", "id": "title", "label": "Title", "default": "Poolside ritual with Arctic White" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Creative direction, photography, and styling from the Fizz lifestyle team." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View more" },
        { "type": "url", "id": "link_url", "label": "Link URL" },
        {
          "type": "select",
          "id": "image_layout",
          "label": "Image layout",
          "options": [
            { "value": "trio", "label": "Three images" },
            { "value": "duo", "label": "Two images" },
            { "value": "single", "label": "Single image" }
          ],
          "default": "trio"
        },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "text", "id": "fallback_1", "label": "Fallback 1", "default": "fizz-lifestyle-gallery-poolside" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "text", "id": "fallback_2", "label": "Fallback 2", "default": "fizz-lifestyle-gallery-commute" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "text", "id": "fallback_3", "label": "Fallback 3", "default": "fizz-lifestyle-gallery-outdoor" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fizz lifestyle gallery",
      "blocks": [
        { "type": "thumbnail", "settings": { "fallback_image": "fizz-lifestyle-gallery-poolside" } },
        { "type": "thumbnail", "settings": { "fallback_image": "fizz-lifestyle-gallery-commute" } },
        { "type": "thumbnail", "settings": { "fallback_image": "fizz-lifestyle-gallery-studio" } },
        { "type": "thumbnail", "settings": { "fallback_image": "fizz-lifestyle-gallery-outdoor" } },
        {
          "type": "gallery_row",
          "settings": {
            "label": "Poolside",
            "title": "Arctic White at golden hour",
            "body": "A sun-drenched afternoon with crisp bubbles, citrus, and the Fizz bottle in its element.",
            "fallback_1": "fizz-lifestyle-gallery-poolside",
            "fallback_2": "fizz-lifestyle-gallery-hero",
            "fallback_3": "fizz-lifestyle-gallery-outdoor"
          }
        },
        {
          "type": "gallery_row",
          "settings": {
            "label": "Commute",
            "title": "Everyday sparkle on the go",
            "body": "From desk to trail — hydration that moves with you.",
            "image_layout": "duo",
            "fallback_1": "fizz-lifestyle-gallery-commute",
            "fallback_2": "fizz-lifestyle-gallery-studio"
          }
        },
        {
          "type": "gallery_row",
          "settings": {
            "label": "Studio",
            "title": "The science of sparkle",
            "body": "Editorial still life exploring texture, light, and carbonation.",
            "image_layout": "single",
            "fallback_1": "fizz-lifestyle-gallery-studio"
          }
        }
      ]
    }
  ]
}
{% endschema %}
