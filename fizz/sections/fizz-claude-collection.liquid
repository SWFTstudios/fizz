<section class="coll" data-screen-label="Collection" aria-label="{{ collection.title | escape }}">
  <header class="coll__hero rv">
    <p class="coll__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="coll__title">{{ section.settings.heading | default: collection.title }}</h1>
    {% assign coll_desc = section.settings.subheading | default: collection.description %}
    {% if coll_desc != blank %}
      <p class="coll__desc">{{ coll_desc | strip_html }}</p>
    {% endif %}
  </header>

  <div class="coll__grid" data-ss-stagger>
    {% paginate collection.products by section.settings.products_per_page %}
      {% for product in collection.products %}
        {% if section.settings.expand_variants and product.variants.size > 1 %}
          {% for variant in product.variants %}
            {% render 'fizz-claude-product-card', product: product, variant: variant, badge: section.settings.badge %}
          {% endfor %}
        {% else %}
          {% render 'fizz-claude-product-card', product: product, badge: section.settings.badge %}
        {% endif %}
      {% else %}
        <p class="coll__empty">{{ section.settings.empty_message }}</p>
      {% endfor %}

      {% if paginate.pages > 1 %}
        <nav class="coll__pager" aria-label="Pagination">
          {% if paginate.previous %}
            <a class="coll__pager-link" href="{{ paginate.previous.url }}">← Previous</a>
          {% endif %}
          <span class="coll__pager-meta">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a class="coll__pager-link" href="{{ paginate.next.url }}">Next →</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="coll__benefits rv">
      {% for block in section.blocks %}
        {% if block.type == 'benefit' %}
          <div class="coll__benefit" {{ block.shopify_attributes }}>
            <p class="coll__benefit-label">{{ block.settings.label }}</p>
            {% if block.settings.detail != blank %}
              <p class="coll__benefit-detail">{{ block.settings.detail }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "fizz-collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop" },
    { "type": "text", "id": "heading", "label": "Heading override" },
    { "type": "textarea", "id": "subheading", "label": "Subheading override" },
    { "type": "checkbox", "id": "expand_variants", "label": "Show variants as separate cards", "default": false },
    { "type": "text", "id": "badge", "label": "Card badge (optional)" },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 36,
      "step": 3,
      "label": "Products per page",
      "default": 24
    },
    { "type": "text", "id": "empty_message", "label": "Empty state message", "default": "No products in this collection yet." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Free shipping over $50" },
        { "type": "text", "id": "detail", "label": "Detail (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection",
      "blocks": [
        { "type": "benefit", "settings": { "label": "Free shipping over $50" } },
        { "type": "benefit", "settings": { "label": "30-day fizz guarantee" } },
        { "type": "benefit", "settings": { "label": "2-yr warranty" } }
      ]
    }
  ]
}
{% endschema %}
