{% render 'fizz-section-spacing', section: section %}

<section class="fizz-collections-rail" data-fizz-collections-rail aria-label="{{ section.settings.heading | escape }}">
  <div class="fizz-collections-rail__header">
    <div>
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div>
      <button type="button" data-fizz-rail-prev aria-label="Scroll left">←</button>
      <button type="button" data-fizz-rail-next aria-label="Scroll right">→</button>
    </div>
  </div>
  <div class="fizz-collections-rail__viewport">
    <div class="fizz-collections-rail__track" data-fizz-rail-track>
      <div class="fizz-collections-rail__set" data-fizz-rail-set>
    {% if section.settings.collection != blank %}
      {% liquid
        assign rail_collection = section.settings.collection
        assign use_variants = false
        if rail_collection.products_count == 1
          assign single_product = rail_collection.products.first
          if single_product.variants.size > 1
            assign use_variants = true
          endif
        endif
      %}
      {% if use_variants %}
        {% for variant in single_product.variants limit: section.settings.product_limit %}
          {% render 'fizz-variant-card', product: single_product, variant: variant, card_style: 'rail' %}
        {% endfor %}
      {% else %}
        {% for product in rail_collection.products limit: section.settings.product_limit %}
          <a href="{{ product.url }}" class="fizz-product-card">
            <div class="fizz-product-card__media">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
            </div>
            <p class="fizz-product-card__title">{{ product.title }}</p>
            <p class="fizz-product-card__price">{{ product.price | money }}</p>
          </a>
        {% endfor %}
      {% endif %}
    {% else %}
      {% for i in (1..4) %}
        <div class="fizz-product-card">
          <div class="fizz-product-card__media"></div>
          <p class="fizz-product-card__title">Product {{ i }}</p>
          <p class="fizz-product-card__price">$34.00</p>
        </div>
      {% endfor %}
    {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fizz collections rail",
  "tag": "section",
  "class": "fizz-collections-rail-section fizz-section--spaced fizz-section--relaxed",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "relaxed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
                { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New Arrivals" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Pick your finish." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "Fizz collections rail" }]
}
{% endschema %}
