{% render 'fizz-section-spacing', section: section %}

<section class="ss-section" aria-label="About">
  <div class="ss-container">
    <div class="ss-about-hero">
      <p class="ss-eyebrow" data-ss-trigger="load" data-ss-fade="up">{{ section.settings.eyebrow }}</p>
      <h1
        class="ss-h1"
        data-ss-trigger="load"
        data-ss-split="words"
        data-ss-duration="0.4"
        data-ss-delay="0.1"
      >
        {{ section.settings.heading }}
      </h1>
      {% if section.settings.intro != blank %}
        <p
          class="ss-h3"
          style="margin-top: 1.5rem; max-width: 40rem;"
          data-ss-trigger="load"
          data-ss-fade="up"
          data-ss-delay="0.3"
        >
          {{ section.settings.intro }}
        </p>
      {% endif %}
    </div>

    <div class="ss-intro-split__row" style="margin-bottom: var(--fizz-space-stack-xl);">
      <div>
        <h2 class="ss-h2" data-ss-trigger="scroll" data-ss-split="words" data-ss-duration="0.35">
          {{ section.settings.story_heading }}
        </h2>
      </div>
      <div>
        {% if section.settings.story_body != blank %}
          <p class="ss-body" data-ss-trigger="scroll" data-ss-fade="up">{{ section.settings.story_body }}</p>
        {% endif %}
        {% if page.content != blank %}
          <div class="ss-body rte" style="margin-top: 1.25rem;" data-ss-trigger="scroll" data-ss-fade="up">
            {{ page.content }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <h2 class="ss-h2" data-ss-trigger="scroll" data-ss-split="words" style="margin-bottom: 0.5rem;">
        {{ section.settings.timeline_heading }}
      </h2>
      <div class="ss-timeline" data-ss-stagger>
        {% for block in section.blocks %}
          {% if block.type == 'milestone' %}
            <article class="ss-timeline__item" {{ block.shopify_attributes }}>
              <p class="ss-timeline__year">{{ block.settings.year }}</p>
              <h3 class="ss-h3">{{ block.settings.title }}</h3>
              {% if block.settings.body != blank %}
                <p class="ss-body" style="margin-top: 0.75rem;">{{ block.settings.body }}</p>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% assign has_faq = false %}
    {% for block in section.blocks %}
      {% if block.type == 'faq' %}
        {% assign has_faq = true %}
      {% endif %}
    {% endfor %}

    {% if has_faq %}
      <div class="ss-faq" style="margin-top: var(--fizz-space-stack-xl); max-width: 48rem;">
        <h2 class="ss-h2" style="margin-bottom: 1.5rem;" data-ss-trigger="scroll" data-ss-split="words">
          {{ section.settings.faq_heading }}
        </h2>
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <details {{ block.shopify_attributes }}>
              <summary>{{ block.settings.question }}</summary>
              <div class="ss-faq__body">{{ block.settings.answer }}</div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SS About",
  "tag": "section",
  "class": "fizz-ss-about fizz-section--spaced fizz-section--default",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Story" },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Our journey began with a simple idea: sparkling water should be portable, delicious, and easy."
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story heading",
      "default": "Built for everyday life"
    },
    {
      "type": "textarea",
      "id": "story_body",
      "label": "Story body",
      "default": "Fizz brings together a reusable bottle, Fizz Charge CO₂, and natural flavor packs so you can carbonate anywhere — desk, trail, kitchen, or travel."
    },
    { "type": "text", "id": "timeline_heading", "label": "Timeline heading", "default": "The timeline" },
    { "type": "text", "id": "faq_heading", "label": "FAQ heading", "default": "Got questions?" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" }
      ],
      "default": "default"
    },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Timeline milestone",
      "settings": [
        { "type": "text", "id": "year", "label": "Year / label", "default": "The start" },
        { "type": "text", "id": "title", "label": "Title", "default": "First prototype" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "We built the first portable Fizz bottle to replace single-use cans." }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Where is Fizz made?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Designed for everyday use with carefully sourced materials and flavors." }
      ]
    }
  ],
  "presets": [
    {
      "name": "SS About",
      "blocks": [
        { "type": "milestone", "settings": { "year": "The start", "title": "First sip", "body": "A kitchen-table idea became a portable carbonation bottle." } },
        { "type": "milestone", "settings": { "year": "Next", "title": "Flavor packs", "body": "In-house flavors made natural taste part of the ritual." } },
        { "type": "milestone", "settings": { "year": "Today", "title": "Everyday fizz", "body": "Bottles, Charge, and flavors for desk, trail, and home." } },
        { "type": "faq", "settings": { "question": "How do I get started?", "answer": "Pick a bottle finish, add Fizz Charge, and try a flavor pack." } }
      ]
    }
  ]
}
{% endschema %}
