{% render 'fizz-section-spacing', section: section %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign pdp_tagline = product.metafields.custom.pdp_tagline
  capture pack_slug
    render 'fizz-pdp-pack-slug', variant: current_variant
  endcapture
  assign pack_slug = pack_slug | strip
%}
<section
  id="shopify-section-{{ section.id }}"
  class="fizz-product-pdp fizz-product-pdp--flavor fizz-pdp-hero"
  data-fizz-pdp-hero
  data-fizz-product-flavor
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
>
  <div class="fizz-pdp-hero__inner">
    <div class="fizz-pdp-hero__grid">
      <div class="fizz-pdp-hero__media-col fizz-commerce-panel fizz-commerce-panel--media">
        <div class="fizz-pdp-hero__main-media fizz-product-pdp__media--pack">
          {% if current_variant.image %}
            {% assign main_src = current_variant.image | image_url: width: 900 %}
            <img data-fizz-pdp-main-image id="fizz-flavor-image" src="{{ main_src }}" alt="{{ current_variant.title | escape }}" class="fizz-flavor-pack-img" width="900" height="900" loading="eager">
          {% else %}
            {% assign main_src = 'flavor-pack-' | append: pack_slug | append: '.png' | asset_url %}
            <img data-fizz-pdp-main-image id="fizz-flavor-image" src="{{ main_src }}" alt="{{ current_variant.title | escape }}" class="fizz-flavor-pack-img" width="900" height="900" loading="eager">
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="fizz-pdp-hero__thumbs">
            {% for image in product.images %}
              <button type="button" class="fizz-pdp-hero__thumb{% if forloop.first %} is-active{% endif %}" data-fizz-pdp-thumb data-full-src="{{ image | image_url: width: 900 }}" data-alt="{{ image.alt | escape }}">
                {{ image | image_url: width: 120 | image_tag: loading: 'lazy', alt: '' }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="fizz-pdp-hero__buy-col fizz-commerce-panel fizz-commerce-panel--buy">
        <div class="fizz-product-pdp__info">
          <p class="fizz-product-pdp__eyebrow fizz-commerce-eyebrow">{{ section.settings.eyebrow }}</p>
          {% if pdp_tagline != blank %}
            <p class="fizz-pdp-tagline">{{ pdp_tagline }}</p>
          {% endif %}
          <h1>{{ product.title }}</h1>
          <p class="fizz-product-pdp__price" data-fizz-pdp-price>{{ current_variant.price | money }} <span>/ sachet</span></p>
          <div class="fizz-product-pdp__desc rte">{{ product.description }}</div>

          {% if product.variants.size > 1 %}
            <div class="fizz-product-pdp__swatches fizz-product-pdp__swatches--flavor" role="group" aria-label="Flavor">
              {% for variant in product.variants %}
                <button
                  type="button"
                  class="fizz-swatch fizz-swatch--flavor{% if variant.id == current_variant.id %} is-active{% endif %}"
                  data-variant-id="{{ variant.id }}"
                  title="{{ variant.title }}"
                >
                  <span class="fizz-swatch__label">{{ variant.title }}</span>
                </button>
              {% endfor %}
            </div>
          {% endif %}

          {% form 'product', product, id: 'fizz-flavor-form' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <button type="submit" class="fizz-product-pdp__cta" data-fizz-pdp-submit>{{ section.settings.cta_label }}</button>
          {% endform %}

          {% if section.settings.natural_copy != blank %}
            <p class="fizz-product-pdp__note">{{ section.settings.natural_copy }}</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="fizz-pdp-sticky-atc" data-fizz-sticky-atc hidden>
    <div class="fizz-pdp-sticky-atc__meta">
      <p class="fizz-pdp-sticky-atc__title">{{ product.title }}</p>
      <p class="fizz-pdp-sticky-atc__price">{{ current_variant.price | money }}</p>
    </div>
    <button type="submit" form="fizz-flavor-form" class="fizz-pdp-sticky-atc__btn">{{ section.settings.cta_label }}</button>
  </div>
</section>

{% schema %}
{
  "name": "Fizz flavor pack PDP",
  "tag": "section",
  "class": "fizz-flavor-pdp-section fizz-section--spaced fizz-section--hero",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "hero"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
                { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Flavor Pack" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Add to cart" },
    {
      "type": "text",
      "id": "natural_copy",
      "label": "Natural flavors note",
      "default": "Made with natural flavors — no high-fructose syrups."
    },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "Fizz flavor pack PDP" }]
}
{% endschema %}
