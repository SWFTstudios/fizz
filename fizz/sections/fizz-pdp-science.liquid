{% render 'fizz-section-spacing', section: section %}

<section class="fizz-pdp-science" aria-label="{{ section.settings.heading | escape }}">
  <div class="fizz-pdp-science__inner">
    <div class="fizz-pdp-science__copy">
      <h2>{{ section.settings.heading }}</h2>
      <p class="fizz-pdp-science__body">{{ section.settings.body }}</p>
      <ul class="fizz-pdp-science__features">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <li {{ block.shopify_attributes }}>
              <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
              <div>
                <strong>{{ block.settings.title }}</strong>
                <span>{{ block.settings.body }}</span>
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
    <div class="fizz-pdp-science__media">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        {% render 'ks-stitch-img', name: 'science-carbonation', alt: section.settings.heading %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP science block",
  "tag": "section",
  "class": "fizz-pdp-science-section fizz-section--spaced fizz-section--relaxed",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "relaxed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
                { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Science of Sparkle" },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Our patented carbonation core transforms ordinary water into a premium sparkling experience in seconds — crisp bubbles, every time."
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "water_drop" },
        { "type": "text", "id": "title", "label": "Title", "default": "Precision Flow" },
        { "type": "text", "id": "body", "label": "Body", "default": "Micro-bubble technology for a smoother, longer-lasting fizz." }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP science block",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "water_drop",
            "title": "Precision Flow",
            "body": "Micro-bubble technology for a smoother, longer-lasting fizz."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "eco",
            "title": "Sustainable Craftsmanship",
            "body": "Engineered to replace single-use plastic bottles for good."
          }
        }
      ]
    }
  ]
}
{% endschema %}
