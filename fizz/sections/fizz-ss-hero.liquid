{% render 'fizz-section-spacing', section: section %}

<section class="ss-section ss-hero" aria-label="Hero">
  <div class="ss-container">
    <div class="ss-hero__grid">
      <div class="ss-hero__copy">
        {% if section.settings.eyebrow != blank %}
          <p class="ss-eyebrow" data-ss-trigger="load" data-ss-fade="up" data-ss-delay="0.05">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h1
          class="ss-h1"
          data-ss-trigger="load"
          data-ss-split="words"
          data-ss-delay="{{ section.settings.heading_delay }}"
          data-ss-duration="0.4"
        >
          {{ section.settings.heading }}
        </h1>
        {% if section.settings.subheading != blank %}
          <p class="ss-body" data-ss-trigger="load" data-ss-fade="up" data-ss-delay="0.35">{{ section.settings.subheading }}</p>
        {% endif %}
        <div class="ss-hero__actions" data-ss-trigger="load" data-ss-fade="up" data-ss-delay="0.45">
          {% if section.settings.cta_label != blank %}
            <a class="ss-btn ss-btn--primary" href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}">
              {{ section.settings.cta_label }}
            </a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a class="ss-btn ss-btn--ghost" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
      </div>
      <div class="ss-hero__media" data-ss-trigger="load" data-ss-fade="up" data-ss-delay="0.25">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', alt: section.settings.heading }}
        {% elsif section.settings.fallback_product != blank and section.settings.fallback_product.featured_image %}
          {{ section.settings.fallback_product.featured_image | image_url: width: 1400 | image_tag: loading: 'eager', alt: section.settings.heading }}
        {% else %}
          {% render 'fizz-bottle-card-media', color_slug: section.settings.fallback_slug, alt: section.settings.heading %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SS Hero",
  "tag": "section",
  "class": "fizz-ss-hero fizz-section--spaced fizz-section--flush",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Portable sparkling water" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sparkling Water, Perfectly Portable" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Carbonate anywhere. Flavor in seconds. Fizz up your day." },
    { "type": "text", "id": "cta_label", "label": "Primary CTA", "default": "Shop Now" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA", "default": "Explore flavors" },
    { "type": "url", "id": "secondary_url", "label": "Secondary CTA URL" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "product", "id": "fallback_product", "label": "Fallback product image" },
    { "type": "text", "id": "fallback_slug", "label": "Fallback bottle color slug", "default": "coral-orange" },
    { "type": "text", "id": "heading_delay", "label": "Heading delay (s)", "default": "0.15" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "hero", "label": "Hero" },
        { "value": "statement", "label": "Statement" }
      ],
      "default": "flush"
    },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "SS Hero" }]
}
{% endschema %}
