{% render 'fizz-section-spacing', section: section %}

<section class="fizz-hero-section" id="hero--content" aria-label="Hero" data-fizz-hero data-autoplay-ms="{{ section.settings.autoplay_seconds | times: 1000 }}">
  <div
    class="fizz-hero-track"
    data-fizz-hero-track
    data-scroll-enabled="{{ section.settings.enable_scroll_animation }}"
    data-scroll-scale-end="{{ section.settings.scroll_scale_end | times: 0.01 }}"
    style="height: {{ section.settings.scroll_track_vh }}vh;"
  >
    {% if section.settings.show_marquee %}
      <div class="fizz-carousel-wrapper" data-fizz-carousel aria-hidden="true">
        <div class="fizz-text-wrapper">
          <div class="fizz-carousel-div-wrapper fizz-carousel-row">
            <div class="fizz-carousel-flex">
              {% for i in (1..8) %}
                <img
                  src="{% if section.settings.logo_dark %}{{ section.settings.logo_dark | image_url: width: 1200 }}{% else %}{{ 'fizz-logo-black.avif' | asset_url }}{% endif %}"
                  alt=""
                  class="fizz-carousel-image"
                  loading="lazy"
                  width="800"
                  height="200"
                >
                <img
                  src="{% if section.settings.logo_light %}{{ section.settings.logo_light | image_url: width: 1200 }}{% else %}{{ 'fizz-logo-white.png' | asset_url }}{% endif %}"
                  alt=""
                  class="fizz-carousel-image"
                  loading="lazy"
                  width="800"
                  height="200"
                >
              {% endfor %}
            </div>
          </div>
          <div class="fizz-carousel-div-wrapper fizz-carousel-row is-reverse">
            <div class="fizz-carousel-flex">
              {% for i in (1..8) %}
                <img
                  src="{% if section.settings.logo_dark %}{{ section.settings.logo_dark | image_url: width: 1200 }}{% else %}{{ 'fizz-logo-black.avif' | asset_url }}{% endif %}"
                  alt=""
                  class="fizz-carousel-image"
                  loading="lazy"
                  width="800"
                  height="200"
                >
                <img
                  src="{% if section.settings.logo_light %}{{ section.settings.logo_light | image_url: width: 1200 }}{% else %}{{ 'fizz-logo-white.png' | asset_url }}{% endif %}"
                  alt=""
                  class="fizz-carousel-image"
                  loading="lazy"
                  width="800"
                  height="200"
                >
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% liquid
      assign hero_copy = section.blocks | where: 'type', 'hero_text' | first
      assign legacy_radius = 2
      assign legacy_shadow_y = 8
      assign legacy_shadow_blur = 32
      assign legacy_shadow_spread = -8
      assign legacy_shadow_opacity = 15
      assign legacy_shadow_enabled = true

      if hero_copy
        assign heading_small = hero_copy.settings.heading_small
        assign heading_large = hero_copy.settings.heading_large
        assign subtext = hero_copy.settings.subtext
        assign cta_label = hero_copy.settings.cta_label
        assign cta_url = hero_copy.settings.cta_url
        assign legacy_radius = hero_copy.settings.glass_corner_radius | default: 2
        assign legacy_shadow_y = hero_copy.settings.glass_shadow_y | default: 8
        assign legacy_shadow_blur = hero_copy.settings.glass_shadow_blur | default: 32
        assign legacy_shadow_spread = hero_copy.settings.glass_shadow_spread | default: -8
        assign legacy_shadow_opacity = hero_copy.settings.glass_shadow_opacity | default: 15
        if hero_copy.settings.glass_shadow_enabled == true
          assign legacy_shadow_enabled = true
        elsif hero_copy.settings.glass_shadow_enabled == false
          assign legacy_shadow_enabled = false
        else
          assign legacy_shadow_enabled = true
        endif

        assign top_radius = hero_copy.settings.top_glass_corner_radius | default: legacy_radius
        assign top_pad_y = hero_copy.settings.top_glass_padding_y | default: 20
        assign top_pad_x = hero_copy.settings.top_glass_padding_x | default: 24
        assign top_shadow_y = hero_copy.settings.top_glass_shadow_y | default: legacy_shadow_y
        assign top_shadow_blur = hero_copy.settings.top_glass_shadow_blur | default: legacy_shadow_blur
        assign top_shadow_spread = hero_copy.settings.top_glass_shadow_spread | default: legacy_shadow_spread
        assign top_shadow_opacity = hero_copy.settings.top_glass_shadow_opacity | default: legacy_shadow_opacity
        if hero_copy.settings.top_glass_shadow_enabled == true
          assign top_shadow_enabled = true
        elsif hero_copy.settings.top_glass_shadow_enabled == false
          assign top_shadow_enabled = false
        else
          assign top_shadow_enabled = legacy_shadow_enabled
        endif

        assign bottom_radius = hero_copy.settings.bottom_glass_corner_radius | default: legacy_radius
        assign bottom_pad_y = hero_copy.settings.bottom_glass_padding_y | default: 20
        assign bottom_pad_x = hero_copy.settings.bottom_glass_padding_x | default: 24
        assign bottom_shadow_y = hero_copy.settings.bottom_glass_shadow_y | default: legacy_shadow_y
        assign bottom_shadow_blur = hero_copy.settings.bottom_glass_shadow_blur | default: legacy_shadow_blur
        assign bottom_shadow_spread = hero_copy.settings.bottom_glass_shadow_spread | default: legacy_shadow_spread
        assign bottom_shadow_opacity = hero_copy.settings.bottom_glass_shadow_opacity | default: legacy_shadow_opacity
        if hero_copy.settings.bottom_glass_shadow_enabled == true
          assign bottom_shadow_enabled = true
        elsif hero_copy.settings.bottom_glass_shadow_enabled == false
          assign bottom_shadow_enabled = false
        else
          assign bottom_shadow_enabled = legacy_shadow_enabled
        endif
      else
        assign heading_small = section.settings.heading_small
        assign heading_large = section.settings.heading_large
        assign subtext = section.settings.subtext
        assign cta_label = section.settings.cta_label
        assign cta_url = section.settings.cta_url
        assign top_radius = legacy_radius
        assign top_pad_y = 20
        assign top_pad_x = 24
        assign top_shadow_enabled = legacy_shadow_enabled
        assign top_shadow_y = legacy_shadow_y
        assign top_shadow_blur = legacy_shadow_blur
        assign top_shadow_spread = legacy_shadow_spread
        assign top_shadow_opacity = legacy_shadow_opacity
        assign bottom_radius = legacy_radius
        assign bottom_pad_y = 20
        assign bottom_pad_x = 24
        assign bottom_shadow_enabled = legacy_shadow_enabled
        assign bottom_shadow_y = legacy_shadow_y
        assign bottom_shadow_blur = legacy_shadow_blur
        assign bottom_shadow_spread = legacy_shadow_spread
        assign bottom_shadow_opacity = legacy_shadow_opacity
      endif
    %}

    {% capture top_glass_style %}
      {% render 'fizz-hero-glass-style',
        radius: top_radius,
        pad_y: top_pad_y,
        pad_x: top_pad_x,
        shadow_enabled: top_shadow_enabled,
        shadow_y: top_shadow_y,
        shadow_blur: top_shadow_blur,
        shadow_spread: top_shadow_spread,
        shadow_opacity: top_shadow_opacity
      %}
    {% endcapture %}
    {% capture bottom_glass_style %}
      {% render 'fizz-hero-glass-style',
        radius: bottom_radius,
        pad_y: bottom_pad_y,
        pad_x: bottom_pad_x,
        shadow_enabled: bottom_shadow_enabled,
        shadow_y: bottom_shadow_y,
        shadow_blur: bottom_shadow_blur,
        shadow_spread: bottom_shadow_spread,
        shadow_opacity: bottom_shadow_opacity
      %}
    {% endcapture %}

    <div class="fizz-video-bg" data-fizz-video-bg>
      <div
        class="fizz-hero-content-wrap"
        data-fizz-hero-content
        {% if hero_copy %}{{ hero_copy.shopify_attributes }}{% endif %}
      >
        <div class="fizz-hero-col-top">
          <div class="fizz-hero-glass" style="{{ top_glass_style | strip }}">
            {% if heading_small != blank %}
              <p class="fizz-hero-heading-sm">{{ heading_small }}</p>
            {% endif %}
            {% if heading_large != blank %}
              <p class="fizz-hero-heading-lg">{{ heading_large }}</p>
            {% endif %}
          </div>
        </div>
        <div class="fizz-hero-col-bottom">
          <div class="fizz-hero-glass" style="{{ bottom_glass_style | strip }}">
            {% if subtext != blank %}
              <p class="fizz-hero-subtext">{{ subtext }}</p>
            {% endif %}
            {% if cta_label != blank %}
              <a href="{{ cta_url | default: '#intro' }}" class="fizz-hero-cta">
                {{ cta_label }} ↓
              </a>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="fizz-hero-slider" data-fizz-hero-slider>
        <div class="fizz-hero-mask" data-fizz-hero-viewport>
          <div class="fizz-hero-track-inner" data-fizz-hero-track-inner>
          {% for block in section.blocks %}
            {% liquid
              assign preset = block.settings.theme_preset | default: 'slide-1'
              assign media_type = block.settings.media_type
              if media_type == blank
                if block.settings.bottle_slug != blank
                  assign media_type = 'image'
                else
                  assign media_type = 'video'
                endif
              endif
            %}
            <div
              class="fizz-hero-slide{% if forloop.first %} is-active{% endif %}"
              data-fizz-hero-slide
              data-theme-preset="{{ preset }}"
              aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="fizz-hero-media">
                {% if media_type == 'image' %}
                  {% if block.settings.bottle_slug != blank %}
                    <div class="fizz-hero-slide-bg fizz-hero-slide-bg--{{ block.settings.bottle_slug }}" aria-hidden="true"></div>
                  {% endif %}
                  {% liquid
                    assign desktop_src = block.settings.image | image_url: width: 2400
                    assign mobile_src = block.settings.image_mobile | image_url: width: 1200
                    if block.settings.image == blank and block.settings.bottle_slug != blank
                      assign desktop_src = 'hero-lifestyle-' | append: block.settings.bottle_slug | append: '.png' | asset_url
                      assign mobile_src = 'hero-lifestyle-' | append: block.settings.bottle_slug | append: '-mobile.png' | asset_url
                    endif
                  %}
                  <img
                    class="fizz-hero-lifestyle"
                    src="{{ desktop_src }}"
                    data-desktop-src="{{ desktop_src }}"
                    {% if mobile_src != blank %}
                      data-mobile-src="{{ mobile_src }}"
                    {% endif %}
                    alt="{{ block.settings.image_alt | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="1920"
                    height="1080"
                  >
                {% else %}
                  {% if block.settings.video != blank %}
                    {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'fizz-hero-video' }}
                  {% elsif block.settings.video_url != blank %}
                    <video autoplay loop muted playsinline class="fizz-hero-video"{% if block.settings.video_poster != blank %} poster="{{ block.settings.video_poster | image_url: width: 1920 }}"{% endif %}>
                      <source src="{{ block.settings.video_url }}" type="video/mp4">
                    </video>
                  {% elsif preset == 'slide-2' %}
                    <video autoplay loop muted playsinline class="fizz-hero-video">
                      <source src="{{ 'fizz-hero-bubbles.mp4' | asset_url }}" type="video/mp4">
                    </video>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
          </div>
        </div>
        <div class="fizz-hero-dots" data-fizz-hero-dots role="tablist" aria-label="Hero slides"></div>
      </div>

      <button type="button" class="fizz-slide-arrow fizz-slide-arrow--left" data-fizz-prev aria-label="Previous slide">
        <img src="{{ 'fizz-arrow-left.svg' | asset_url }}" alt="" width="24" height="24">
      </button>
      <button type="button" class="fizz-slide-arrow fizz-slide-arrow--right" data-fizz-next aria-label="Next slide">
        <img src="{{ 'fizz-arrow-right.svg' | asset_url }}" alt="" width="24" height="24">
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fizz hero slider",
  "tag": "section",
  "class": "fizz-hero-section fizz-section--flush",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "hero"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
        { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    {
      "type": "paragraph",
      "content": "Edit the hero headline, subtext, and CTA in the **Hero text** block below (or click the text overlay in the preview)."
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show logo marquee",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo_dark",
      "label": "Marquee logo (dark)"
    },
    {
      "type": "image_picker",
      "id": "logo_light",
      "label": "Marquee logo (light)"
    },
    {
      "type": "range",
      "id": "autoplay_seconds",
      "label": "Autoplay interval (seconds)",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 4,
      "info": "Set to 0 to disable autoplay"
    },
    {
      "type": "header",
      "content": "Scroll animation"
    },
    {
      "type": "checkbox",
      "id": "enable_scroll_animation",
      "label": "Enable hero scroll scale (Webflow-style)",
      "default": true,
      "info": "Sticky hero frame scales down as you scroll through the track"
    },
    {
      "type": "range",
      "id": "scroll_track_vh",
      "label": "Scroll track height (vh)",
      "min": 200,
      "max": 400,
      "step": 10,
      "default": 300,
      "info": "Webflow uses 300vh — more height = longer scale animation"
    },
    {
      "type": "range",
      "id": "scroll_scale_end",
      "label": "Scale at end of scroll (%)",
      "min": 50,
      "max": 100,
      "step": 1,
      "default": 76,
      "info": "Webflow scrubs the sticky frame from 100% down to this size"
    },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "hero_text",
      "name": "Hero text",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Headline"
        },
        {
          "type": "text",
          "id": "heading_small",
          "label": "Heading line 1",
          "default": "Elevate Your"
        },
        {
          "type": "text",
          "id": "heading_large",
          "label": "Heading line 2",
          "default": "Hydration"
        },
        {
          "type": "header",
          "content": "Subtext & CTA"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Enjoy healthy, hydrating flavor. Now with a sparkling twist."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Fizz Up Your Day",
          "info": "Leave blank to hide the button"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA link",
          "info": "Defaults to the intro section (#intro) when empty"
        },
        {
          "type": "header",
          "content": "Top card (headline)"
        },
        {
          "type": "range",
          "id": "top_glass_corner_radius",
          "label": "Corner radius",
          "min": 0,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 2
        },
        {
          "type": "range",
          "id": "top_glass_padding_y",
          "label": "Padding vertical",
          "min": 0,
          "max": 64,
          "step": 1,
          "unit": "px",
          "default": 20
        },
        {
          "type": "range",
          "id": "top_glass_padding_x",
          "label": "Padding horizontal",
          "min": 0,
          "max": 64,
          "step": 1,
          "unit": "px",
          "default": 24
        },
        {
          "type": "checkbox",
          "id": "top_glass_shadow_enabled",
          "label": "Show drop shadow",
          "default": true
        },
        {
          "type": "range",
          "id": "top_glass_shadow_y",
          "label": "Shadow offset Y",
          "min": 0,
          "max": 40,
          "step": 1,
          "unit": "px",
          "default": 8
        },
        {
          "type": "range",
          "id": "top_glass_shadow_blur",
          "label": "Shadow blur",
          "min": 0,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 32
        },
        {
          "type": "range",
          "id": "top_glass_shadow_spread",
          "label": "Shadow spread",
          "min": -40,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": -8
        },
        {
          "type": "range",
          "id": "top_glass_shadow_opacity",
          "label": "Shadow opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 15
        },
        {
          "type": "header",
          "content": "Bottom card (subtext & CTA)"
        },
        {
          "type": "range",
          "id": "bottom_glass_corner_radius",
          "label": "Corner radius",
          "min": 0,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 2
        },
        {
          "type": "range",
          "id": "bottom_glass_padding_y",
          "label": "Padding vertical",
          "min": 0,
          "max": 64,
          "step": 1,
          "unit": "px",
          "default": 20
        },
        {
          "type": "range",
          "id": "bottom_glass_padding_x",
          "label": "Padding horizontal",
          "min": 0,
          "max": 64,
          "step": 1,
          "unit": "px",
          "default": 24
        },
        {
          "type": "checkbox",
          "id": "bottom_glass_shadow_enabled",
          "label": "Show drop shadow",
          "default": true
        },
        {
          "type": "range",
          "id": "bottom_glass_shadow_y",
          "label": "Shadow offset Y",
          "min": 0,
          "max": 40,
          "step": 1,
          "unit": "px",
          "default": 8
        },
        {
          "type": "range",
          "id": "bottom_glass_shadow_blur",
          "label": "Shadow blur",
          "min": 0,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 32
        },
        {
          "type": "range",
          "id": "bottom_glass_shadow_spread",
          "label": "Shadow spread",
          "min": -40,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": -8
        },
        {
          "type": "range",
          "id": "bottom_glass_shadow_opacity",
          "label": "Shadow opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 15
        }
      ]
    },
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "select",
          "id": "theme_preset",
          "label": "Color theme",
          "options": [
            { "value": "slide-1", "label": "Blue bokeh (light)" },
            { "value": "slide-2", "label": "Black bubbles (dark)" },
            { "value": "slide-3", "label": "Coral orange" },
            { "value": "slide-4", "label": "Charcoal black" },
            { "value": "slide-5", "label": "Sage green" },
            { "value": "slide-6", "label": "Steel navy" },
            { "value": "slide-7", "label": "Arctic white" },
            { "value": "slide-8", "label": "Electric blue" }
          ],
          "default": "slide-1"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "video", "label": "Video" },
            { "value": "image", "label": "Lifestyle image" }
          ],
          "default": "video"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video upload"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (MP4)",
          "info": "Used when no video is uploaded"
        },
        {
          "type": "image_picker",
          "id": "video_poster",
          "label": "Video poster"
        },
        {
          "type": "select",
          "id": "bottle_slug",
          "label": "Lifestyle bottle (fallback asset)",
          "options": [
            { "value": "", "label": "None" },
            { "value": "coral-orange", "label": "Coral orange" },
            { "value": "charcoal-black", "label": "Charcoal black" },
            { "value": "sage-green", "label": "Sage green" },
            { "value": "steel-navy", "label": "Steel navy" },
            { "value": "arctic-white", "label": "Arctic white" },
            { "value": "electric-blue", "label": "Electric blue" }
          ],
          "default": ""
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Lifestyle image (desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Lifestyle image (mobile)"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fizz hero slider",
      "blocks": [
        {
          "type": "hero_text",
          "settings": {
            "heading_small": "Elevate Your",
            "heading_large": "Hydration",
            "subtext": "Enjoy healthy, hydrating flavor. Now with a sparkling twist.",
            "cta_label": "Fizz Up Your Day",
            "top_glass_corner_radius": 2,
            "top_glass_padding_y": 20,
            "top_glass_padding_x": 24,
            "top_glass_shadow_enabled": true,
            "top_glass_shadow_y": 8,
            "top_glass_shadow_blur": 32,
            "top_glass_shadow_spread": -8,
            "top_glass_shadow_opacity": 15,
            "bottom_glass_corner_radius": 2,
            "bottom_glass_padding_y": 20,
            "bottom_glass_padding_x": 24,
            "bottom_glass_shadow_enabled": true,
            "bottom_glass_shadow_y": 8,
            "bottom_glass_shadow_blur": 32,
            "bottom_glass_shadow_spread": -8,
            "bottom_glass_shadow_opacity": 15
