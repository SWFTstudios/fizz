{% render 'fizz-section-spacing', section: section %}

<section class="fizz-cart" data-fizz-cart aria-label="Shopping cart">
  <div class="fizz-cart__inner">
    {% if cart.item_count > 0 %}
      <header class="fizz-cart__header">
        <h1>{{ section.settings.heading }}</h1>
        <p class="fizz-cart__count">{{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %}</p>
      </header>

      <form action="{{ routes.cart_url }}" method="post" id="fizz-cart-form">
        <div class="fizz-cart__layout">
          {% render 'fizz-cart-drawer-content',
            remove_label: section.settings.remove_label,
            checkout_label: section.settings.checkout_label,
            continue_label: section.settings.continue_label,
            subtotal_label: section.settings.subtotal_label,
            summary_heading: section.settings.summary_heading,
            shipping_note: section.settings.shipping_note,
            empty_heading: section.settings.empty_heading,
            empty_body: section.settings.empty_body,
            empty_bottle_label: section.settings.empty_bottle_label,
            empty_flavor_label: section.settings.empty_flavor_label,
            empty_co2_label: section.settings.empty_co2_label,
            context: 'page'
          %}
        </div>
      </form>
    {% else %}
      {% render 'fizz-cart-drawer-content',
        empty_heading: section.settings.empty_heading,
        empty_body: section.settings.empty_body,
        empty_bottle_label: section.settings.empty_bottle_label,
        empty_flavor_label: section.settings.empty_flavor_label,
        empty_co2_label: section.settings.empty_co2_label,
        context: 'page'
      %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Fizz premium cart",
  "tag": "section",
  "class": "fizz-cart-section fizz-section--spaced fizz-section--default",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
                { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your cart" },
    { "type": "text", "id": "summary_heading", "label": "Summary heading", "default": "Order summary" },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal label", "default": "Subtotal" },
    { "type": "text", "id": "shipping_note", "label": "Shipping note", "default": "Shipping and taxes calculated at checkout." },
    { "type": "text", "id": "checkout_label", "label": "Checkout CTA", "default": "Checkout" },
    { "type": "text", "id": "continue_label", "label": "Continue shopping", "default": "Continue shopping" },
    { "type": "text", "id": "remove_label", "label": "Remove label", "default": "Remove" },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "Your cart is empty" },
    { "type": "textarea", "id": "empty_body", "label": "Empty body", "default": "Add a bottle, flavors, or CO₂ refills to get started." },
    { "type": "text", "id": "empty_bottle_label", "label": "Empty — bottles", "default": "Shop bottles" },
    { "type": "text", "id": "empty_flavor_label", "label": "Empty — flavors", "default": "Shop flavors" },
    { "type": "text", "id": "empty_co2_label", "label": "Empty — CO2", "default": "Shop CO₂" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "Fizz premium cart" }]
}
{% endschema %}
