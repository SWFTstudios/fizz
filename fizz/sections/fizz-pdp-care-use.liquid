{% render 'fizz-section-spacing', section: section %}

{% liquid
  assign how_to = product.metafields.custom.how_to_use
  assign care = product.metafields.custom.care_instructions
  assign warranty = product.metafields.custom.warranty_note
  assign has_content = false
  if how_to != blank or care != blank or warranty != blank
    assign has_content = true
  endif
%}

{% if has_content or section.blocks.size > 0 %}
  <section class="fizz-pdp-care-use" aria-label="{{ section.settings.heading | escape }}">
    <div class="fizz-pdp-care-use__inner">
      <h2>{{ section.settings.heading }}</h2>

      <div class="fizz-pdp-care-use__tabs" data-fizz-care-tabs>
        {% if how_to != blank %}
          <details class="fizz-pdp-care-use__panel" open>
            <summary>{{ section.settings.how_to_label }}</summary>
            <div class="fizz-pdp-care-use__content rte">{{ how_to | metafield_text }}</div>
          </details>
        {% endif %}

        {% if care != blank %}
          <details class="fizz-pdp-care-use__panel"{% unless how_to != blank %} open{% endunless %}>
            <summary>{{ section.settings.care_label }}</summary>
            <div class="fizz-pdp-care-use__content rte">{{ care | metafield_text }}</div>
          </details>
        {% endif %}

        {% if warranty != blank %}
          <details class="fizz-pdp-care-use__panel">
            <summary>{{ section.settings.warranty_label }}</summary>
            <div class="fizz-pdp-care-use__content rte">{{ warranty | metafield_text }}</div>
          </details>
        {% endif %}

        {% for block in section.blocks %}
          {% if block.type == 'panel' %}
            <details class="fizz-pdp-care-use__panel" {{ block.shopify_attributes }}>
              <summary>{{ block.settings.title }}</summary>
              <div class="fizz-pdp-care-use__content rte">{{ block.settings.body }}</div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "PDP care and use",
  "tag": "section",
  "class": "fizz-pdp-care-use-section fizz-section--spaced fizz-section--relaxed",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "relaxed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
                { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to use & care" },
    { "type": "text", "id": "how_to_label", "label": "How to use label", "default": "How to use" },
    { "type": "text", "id": "care_label", "label": "Care label", "default": "Care & cleaning" },
    { "type": "text", "id": "warranty_label", "label": "Warranty label", "default": "Warranty" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Extra panel",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Safety" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Always fizz water before adding flavor.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "PDP care and use" }]
}
{% endschema %}
