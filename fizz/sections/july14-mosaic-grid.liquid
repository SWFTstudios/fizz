<section
  class="j14-mosaic"
  id="{{ section.settings.anchor_id | default: 'gallery' }}"
  data-j14-mosaic
  style="--mosaic-gap: {{ section.settings.gap }}px; --mosaic-radius: {{ section.settings.radius }}px;"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="j14-visually-hidden">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div
    class="j14-mosaic__grid j14-mosaic__grid--m{{ section.settings.mobile_columns }} j14-mosaic__grid--d{{ section.settings.desktop_columns }}"
    data-j14-mosaic-grid
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign span_desktop = block.settings.span | default: 4
        assign tag = 'div'
        if block.settings.link != blank
          assign tag = 'a'
        endif
      -%}
      <{{ tag }}
        {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
        class="j14-tile j14-tile--span{{ span_desktop }}{% if block.settings.tall %} j14-tile--tall{% endif %}{% if block.settings.wide_mobile %} j14-tile--wide-m{% endif %}"
        data-j14-tile
        {{ block.shopify_attributes }}
      >
        {%- render 'july14-media',
          video: block.settings.video,
          video_url: block.settings.video_url,
          image: block.settings.image,
          asset: block.settings.asset,
          alt: block.settings.caption,
          class: 'j14-tile__media',
          sizes: '(min-width: 750px) 33vw, 100vw'
        -%}
        {%- if block.settings.caption != blank -%}
          <span class="j14-tile__caption">{{ block.settings.caption | escape }}</span>
        {%- endif -%}
      </{{ tag }}>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "July14 Media Mosaic",
  "tag": "section",
  "class": "j14-mosaic-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Accessible heading",
      "default": "Lifestyle gallery"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "gallery"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "6", "label": "6 (dense)" },
        { "value": "12", "label": "12 (fine control)" }
      ],
      "default": "12"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Tile gap",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Tile corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Media tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Overrides the image. Autoplays muted."
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "External video",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "text",
          "id": "asset",
          "label": "Theme asset fallback",
          "info": "Advanced: filename of a theme asset."
        },
        {
          "type": "range",
          "id": "span",
          "label": "Width (desktop columns of 12)",
          "min": 2,
          "max": 12,
          "step": 1,
          "default": 4
        },
        {
          "type": "checkbox",
          "id": "tall",
          "label": "Double height",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "wide_mobile",
          "label": "Full width on mobile",
          "default": false
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "July14 Media Mosaic",
      "blocks": [
        { "type": "tile", "settings": { "asset": "stitch-bottle-steel-navy-desk.jpg", "span": 4 } },
        { "type": "tile", "settings": { "asset": "stitch-bottle-coral-orange-pool.jpg", "span": 4 } },
        { "type": "tile", "settings": { "asset": "stitch-bottle-electric-blue-water.jpg", "span": 4 } },
        { "type": "tile", "settings": { "asset": "stitch-bottle-sage-green-kitchen.jpg", "span": 4, "wide_mobile": true } },
        { "type": "tile", "settings": { "asset": "stitch-beach-arctic-white.jpg", "span": 8 } },
        { "type": "tile", "settings": { "asset": "stitch-bottle-charcoal-black-dinner.jpg", "span": 6 } },
        { "type": "tile", "settings": { "asset": "stitch-flavor-packs-lifestyle.jpg", "span": 6 } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index", "page"]
  }
}
{% endschema %}
