{% render 'fizz-section-spacing', section: section %}

<section class="relative min-h-[600px] flex items-center overflow-hidden ks-reveal opacity-0 translate-y-10 transition-all duration-1000">
  <div class="absolute inset-0">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'w-full h-full object-cover' }}
    {% else %}
      {% render 'ks-stitch-img', name: 'hero-hiker-sunrise', alt: section.settings.heading, class: 'w-full h-full object-cover' %}
    {% endif %}
    <div class="absolute inset-0 bg-background/60"></div>
  </div>
  <div class="relative z-10 px-margin-mobile md:px-margin-desktop max-w-max-width mx-auto w-full">
    <div class="max-w-xl">
      <span class="font-label-caps text-primary tracking-widest uppercase mb-4 block">{{ section.settings.eyebrow }}</span>
      <h2 class="font-display-xl text-[32px] md:text-[56px] leading-tight mb-8">{{ section.settings.heading }}</h2>
      <p class="text-on-surface-variant text-xl leading-relaxed mb-10">{{ section.settings.body }}</p>
      {% if section.settings.link_url != blank %}
        <a href="{{ section.settings.link_url }}" class="border-b-2 border-primary text-primary font-label-caps pb-2 hover:opacity-70 transition-all">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KS Brand Mission",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "statement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
        { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Mission" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "HYDRATION FOR ANY JOURNEY." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "From the highest peaks to the most intense training sessions, Fizz is your constant companion." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "READ OUR STORY" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "KS Brand Mission" }]
}
{% endschema %}
