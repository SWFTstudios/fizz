{% render 'fizz-section-spacing', section: section %}

{% liquid
  assign hero_heading = section.settings.heading
  if hero_heading == blank
    assign hero_heading = collection.title
  endif

  assign hero_subheading = section.settings.subheading
  if hero_subheading == blank and collection.description != blank
    assign hero_subheading = collection.description
  endif
%}
<section
  class="hero-pattern w-full h-[60vh] flex items-end justify-center pb-20 relative ks-reveal opacity-0 translate-y-10 transition-all duration-1000"
  style="background-image: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, #000 100%), url('{% if section.settings.image %}{{ section.settings.image | image_url: width: 2000 }}{% else %}{{ 'stitch-science-carbonation.jpg' | asset_url }}{% endif %}');"
>
  <div class="text-center z-10 px-margin-mobile">
    <h1 class="font-display-xl text-display-xl tracking-tighter uppercase mb-4 text-on-surface">{{ hero_heading }}</h1>
    {% if hero_subheading != blank %}
      <p class="font-body-md text-on-surface-variant max-w-2xl mx-auto">{{ hero_subheading }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "KS Collection Hero",
  "settings": [
    { "type": "header", "content": "Section spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "options": [
        { "value": "flush", "label": "None" },
        { "value": "compact", "label": "Compact" },
        { "value": "default", "label": "Default" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "statement", "label": "Statement" },
        { "value": "hero", "label": "Hero band" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "hero"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (custom)",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (custom)",
      "default": 96
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "options": [
        { "value": "theme", "label": "Theme default" },
        { "value": "full", "label": "Full width" },
        { "value": "none", "label": "None" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "theme"
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding left (custom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding right (custom)",
      "default": 20
    },
    { "type": "image_picker", "id": "image", "label": "Hero background" },
    { "type": "text", "id": "heading", "label": "Heading", "info": "Leave blank to use the collection title." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "info": "Leave blank to use the collection description." },
    { "type": "header", "content": "Section background" },
    { "type": "color", "id": "background_color", "label": "Background color" }
  ],
  "presets": [{ "name": "KS Collection Hero" }]
}
{% endschema %}
