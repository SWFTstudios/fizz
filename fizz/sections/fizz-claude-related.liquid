{% liquid
  assign source_collection = section.settings.collection
  if source_collection == blank and collection != blank
    assign source_collection = collection
  endif
  assign limit = section.settings.product_limit | default: 4
  assign shown = 0
%}

{% if source_collection != blank and source_collection.products_count > 1 %}
  <section class="related rv" data-screen-label="Related products" aria-label="{{ section.settings.heading }}">
    <div class="related__head">
      <p class="related__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="related__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="related__grid">
      {% for item in source_collection.products %}
        {% if item.id == product.id %}
          {% continue %}
        {% endif %}
        {% render 'fizz-claude-product-card', product: item %}
        {% assign shown = shown | plus: 1 %}
        {% if shown >= limit %}
          {% break %}
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.view_all_url != blank %}
      <a class="related__link" href="{{ section.settings.view_all_url }}">{{ section.settings.view_all_label }}</a>
    {% endif %}
  </section>
{% endif %}

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "class": "fizz-related",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Also try" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More to fizz" },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Defaults to the product's current collection when empty."
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Max products",
      "default": 4
    },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Shop all" },
    { "type": "url", "id": "view_all_url", "label": "View all link" }
  ],
  "presets": [{ "name": "Related products" }]
}
{% endschema %}
