<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'j14-base.css' | asset_url | stylesheet_tag }}
    {% render 'j14-theme-tokens' %}
  </head>
  <body class="j14 j14-password">
    <main class="j14-password__main">
      <h1 class="j14-password__title">{{ shop.name }}</h1>
      <p class="j14-password__note">{{ 'general.password_page.opening_soon' | t }}</p>
      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <label class="j14-visually-hidden" for="Password">{{ 'general.password_page.password_label' | t }}</label>
        <input
          type="password"
          name="password"
          id="Password"
          class="j14-input"
          placeholder="{{ 'general.password_page.password_label' | t }}"
        >
        <button type="submit" class="j14-btn">{{ 'general.password_page.enter' | t }}</button>
      {% endform %}
    </main>
  </body>
</html>
