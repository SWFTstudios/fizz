{%- assign step_count = section.blocks.size | at_least: 1 -%}
<section
  class="j14-how"
  id="{{ section.settings.anchor_id | default: 'how' }}"
  data-j14-how
  style="--how-steps: {{ step_count }};"
>
  <div class="j14-how__track" data-j14-how-track>
    <div class="j14-how__sticky">
      <div class="j14-how__stage">
        {%- for block in section.blocks -%}
          <figure
            class="j14-how__layer{% if forloop.first %} is-active{% endif %}"
            data-j14-how-layer
            {{ block.shopify_attributes }}
          >
            {%- render 'j14-media',
              video: block.settings.video,
              image: block.settings.image,
              asset: block.settings.asset,
              alt: block.settings.title,
              class: 'j14-how__img',
              sizes: '(min-width: 750px) 55vw, 100vw'
            -%}
          </figure>
        {%- endfor -%}
        <div class="j14-how__stage-meta">
          <span class="j14-how__counter" data-j14-how-counter>01 / {{ step_count | prepend: '0' | slice: -2, 2 }}</span>
          <span class="j14-how__progress" aria-hidden="true"><span class="j14-how__progress-fill"></span></span>
        </div>
      </div>

      <div class="j14-how__panel">
        <div class="j14-how__head">
          {%- if section.settings.eyebrow != blank -%}
            <p class="j14-eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="j14-heading j14-how__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
        </div>
        <ol class="j14-how__steps">
          {%- for block in section.blocks -%}
            <li
              class="j14-how__step{% if forloop.first %} is-active{% endif %}"
              data-j14-how-step
              {{ block.shopify_attributes }}
            >
              <span class="j14-how__step-num" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <h3 class="j14-how__step-title">{{ block.settings.title | escape }}</h3>
              {%- if block.settings.body != blank -%}
                <div class="j14-how__step-body">{{ block.settings.body }}</div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ol>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "J14 How To Use",
  "tag": "section",
  "class": "j14-how-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fizz in three moves"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "how"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fill with cold water"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Cold water carbonates best. Fill to the line, no further.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Overrides the photo. Autoplays muted."
        },
        {
          "type": "text",
          "id": "asset",
          "label": "Theme asset fallback",
          "info": "Advanced: filename of a theme asset."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "J14 How To Use",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Fill with cold water",
            "body": "<p>Cold water carbonates best. Fill to the line, no further.</p>",
            "asset": "j14-how-fill-arctic-white.jpg"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Twist the pod",
            "body": "<p>Lock a CO2 pod into the base and give it a quarter turn.</p>",
            "asset": "j14-how-twist-arctic-white.jpg"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Sip the sparkle",
            "body": "<p>Add a flavor pack if you like. Bubbles in under ten seconds.</p>",
            "asset": "j14-how-sip-arctic-white.jpg"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index", "page", "product"]
  }
}
{% endschema %}
