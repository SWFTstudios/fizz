<section class="j14-password__panel">
  <h1 class="j14-password__title">{{ shop.name }}</h1>
  <p class="j14-password__note">{{ section.settings.note | default: 'Opening soon' | escape }}</p>
  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <label class="j14-visually-hidden" for="Password">{{ 'general.password_page.password_label' | t }}</label>
    <input
      type="password"
      name="password"
      id="Password"
      class="j14-input"
      placeholder="{{ 'general.password_page.password_label' | t }}"
    >
    <button type="submit" class="j14-btn">{{ 'general.password_page.enter' | t }}</button>
  {% endform %}
</section>

{% schema %}
{
  "name": "J14 Password",
  "tag": "section",
  "class": "j14-password-section",
  "settings": [
    {
      "type": "text",
      "id": "note",
      "label": "Note",
      "default": "Opening soon"
    }
  ],
  "enabled_on": {
    "templates": ["password"]
  }
}
{% endschema %}
