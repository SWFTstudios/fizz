<section class="j14-list-collections">
  <header class="j14-collection__head">
    <p class="j14-eyebrow">{{ section.settings.eyebrow | default: 'Browse' | escape }}</p>
    <h1 class="j14-heading j14-collection__title">{{ section.settings.heading | default: 'Collections' | escape }}</h1>
  </header>

  <div class="j14-collection__grid j14-collection__grid--3">
    {%- for collection in collections -%}
      <article class="j14-card">
        <a href="{{ collection.url }}" class="j14-card__link">
          <div class="j14-card__media j14-card__media--lime">
            <span class="j14-card__wash" aria-hidden="true"></span>
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 900 | image_tag: class: 'j14-card__img j14-card__img--ph', loading: 'lazy', sizes: '(min-width: 750px) 33vw, 50vw', widths: '360, 540, 720, 900', alt: collection.title }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'j14-card__img j14-card__img--ph' }}
            {%- endif -%}
          </div>
          <div class="j14-card__info">
            <h2 class="j14-card__title">{{ collection.title | escape }}</h2>
          </div>
        </a>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "J14 Collections List",
  "tag": "section",
  "class": "j14-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Browse"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    }
  ],
  "enabled_on": {
    "templates": ["list-collections"]
  }
}
{% endschema %}
