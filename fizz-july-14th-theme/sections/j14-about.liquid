<section class="j14-about" id="{{ section.settings.anchor_id | default: 'about' }}">
  <div class="j14-about__story">
    <div class="j14-about__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="j14-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="j14-heading j14-about__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="j14-about__body">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a class="j14-btn" href="{{ section.settings.cta_url | default: routes.root_url }}">
          {{- section.settings.cta_label | escape -}}
        </a>
      {%- endif -%}
    </div>
    <div class="j14-about__media">
      {%- render 'j14-media',
        video: section.settings.video,
        image: section.settings.image,
        asset: section.settings.asset,
        alt: section.settings.heading,
        class: 'j14-about__img',
        sizes: '(min-width: 750px) 45vw, 100vw'
      -%}
    </div>
  </div>

  <div class="j14-sustain">
    <div class="j14-sustain__head">
      {%- if section.settings.sustain_eyebrow != blank -%}
        <p class="j14-eyebrow">{{ section.settings.sustain_eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.sustain_heading != blank -%}
        <h3 class="j14-heading j14-sustain__heading">{{ section.settings.sustain_heading | escape }}</h3>
      {%- endif -%}
      {%- if section.settings.sustain_body != blank -%}
        <div class="j14-sustain__body">{{ section.settings.sustain_body }}</div>
      {%- endif -%}
    </div>
    {%- if section.blocks.size > 0 -%}
      <ul class="j14-sustain__grid">
        {%- for block in section.blocks -%}
          <li class="j14-sustain__item" {{ block.shopify_attributes }}>
            {%- if block.settings.stat != blank -%}
              <span class="j14-sustain__stat">{{ block.settings.stat | escape }}</span>
            {%- endif -%}
            <h4 class="j14-sustain__title">{{ block.settings.title | escape }}</h4>
            {%- if block.settings.body != blank -%}
              <div class="j14-sustain__text">{{ block.settings.body }}</div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "J14 About + Sustainability",
  "tag": "section",
  "class": "j14-about-section",
  "settings": [
    {
      "type": "header",
      "content": "About us"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bubbles without the baggage"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>We started Fizz because sparkling water should not need a truck, a fridge, or a mountain of cans. One bottle, one pod, endless sparkle.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Overrides the image. Autoplays muted."
    },
    {
      "type": "text",
      "id": "asset",
      "label": "Theme asset fallback",
      "default": "fizz-bottle-hero.jpg",
      "info": "Advanced: filename of a theme asset."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "about"
    },
    {
      "type": "header",
      "content": "Sustainability"
    },
    {
      "type": "text",
      "id": "sustain_eyebrow",
      "label": "Eyebrow",
      "default": "Sustainability"
    },
    {
      "type": "text",
      "id": "sustain_heading",
      "label": "Heading",
      "default": "Better for the planet, by design"
    },
    {
      "type": "richtext",
      "id": "sustain_body",
      "label": "Body",
      "default": "<p>Every part of the system is designed to be refilled, returned, or recycled.</p>"
    }
  ],
  "blocks": [
    {
      "type": "claim",
      "name": "Sustainability claim",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Stat",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cans replaced per bottle"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "J14 About + Sustainability",
      "blocks": [
        {
          "type": "claim",
          "settings": {
            "stat": "500+",
            "title": "Cans replaced per bottle",
            "body": "<p>One reusable bottle keeps hundreds of single-use cans out of circulation.</p>"
          }
        },
        {
          "type": "claim",
          "settings": {
            "stat": "100%",
            "title": "Recyclable CO2 pods",
            "body": "<p>Send pods back with the prepaid label and we refill them.</p>"
          }
        },
        {
          "type": "claim",
          "settings": {
            "stat": "0",
            "title": "Plastic shipped in water",
            "body": "<p>We ship flavor, not water. Your tap does the heavy lifting.</p>"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index", "page"]
  }
}
{% endschema %}
