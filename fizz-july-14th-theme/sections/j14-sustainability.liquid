<section class="j14-sustain j14-sustain--standalone" id="{{ section.settings.anchor_id | default: 'sustainability' }}">
  <div class="j14-sustain__head">
    {%- if section.settings.eyebrow != blank -%}
      <p class="j14-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="j14-heading j14-sustain__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="j14-sustain__body">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a class="j14-btn" href="{{ section.settings.cta_url | default: routes.root_url }}" style="margin-top: 1.25rem;">
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}
  </div>

  {%- if section.settings.image != blank or section.settings.video != blank or section.settings.asset != blank -%}
    <div class="j14-sustain__media" style="margin: 2rem 0;">
      {%- render 'j14-media',
        video: section.settings.video,
        image: section.settings.image,
        asset: section.settings.asset,
        alt: section.settings.heading,
        class: 'j14-about__img',
        sizes: '(min-width: 750px) 60vw, 100vw'
      -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <ul class="j14-sustain__grid">
      {%- for block in section.blocks -%}
        <li class="j14-sustain__item" {{ block.shopify_attributes }}>
          {%- if block.settings.stat != blank -%}
            <span class="j14-sustain__stat">{{ block.settings.stat | escape }}</span>
          {%- endif -%}
          <h3 class="j14-sustain__title">{{ block.settings.title | escape }}</h3>
          {%- if block.settings.body != blank -%}
            <div class="j14-sustain__text">{{ block.settings.body }}</div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "J14 Sustainability",
  "tag": "section",
  "class": "j14-sustainability-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sustainability"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Better for the planet, by design"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Every part of the system is designed to be refilled, returned, or recycled.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "asset",
      "label": "Theme asset fallback"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "sustainability"
    }
  ],
  "blocks": [
    {
      "type": "claim",
      "name": "Sustainability claim",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Stat",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cans replaced per bottle"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "J14 Sustainability",
      "blocks": [
        {
          "type": "claim",
          "settings": {
            "stat": "500+",
            "title": "Cans replaced per bottle",
            "body": "<p>One reusable bottle keeps hundreds of single-use cans out of circulation.</p>"
          }
        },
        {
          "type": "claim",
          "settings": {
            "stat": "100%",
            "title": "Recyclable CO2 pods",
            "body": "<p>Send pods back with the prepaid label and we refill them.</p>"
          }
        },
        {
          "type": "claim",
          "settings": {
            "stat": "0",
            "title": "Plastic shipped in water",
            "body": "<p>We ship flavor, not water. Your tap does the heavy lifting.</p>"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index", "page"]
  }
}
{% endschema %}
