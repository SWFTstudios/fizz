{%- liquid
  assign cart_count = cart.item_count
  assign bg_start = section.settings.bg_start | default: '#f4f3ee'
  assign bg_end = section.settings.bg_end | default: '#e9e7df'
  assign opacity_pct = section.settings.bg_opacity | default: 92
  assign opacity = opacity_pct | times: 1.0 | divided_by: 100.0
  assign text_color = section.settings.text_color | default: '#111214'
  assign blur_enabled = section.settings.blur_background
  if blur_enabled == nil
    assign blur_enabled = true
  endif
  assign blur_amount = section.settings.blur_amount | default: 12
  assign gradient_angle = section.settings.gradient_angle | default: 180

  assign bg_start_a = bg_start | color_modify: 'alpha', opacity
  assign bg_end_a = bg_end | color_modify: 'alpha', opacity
  assign text_rgb = text_color | color_to_rgb | remove: 'rgb(' | remove: ')'

  if blur_enabled
    assign blur_value = 'blur(' | append: blur_amount | append: 'px)'
  else
    assign blur_value = 'none'
  endif

  assign hdr_bg = 'linear-gradient(' | append: gradient_angle | append: 'deg, ' | append: bg_start_a | append: ', ' | append: bg_end_a | append: ')'

  assign menu_match = section.settings.menu_match_header
  if menu_match == nil
    assign menu_match = true
  endif

  if menu_match
    assign menu_bg = hdr_bg
    assign menu_blur_value = blur_value
    assign menu_blur_on = blur_enabled
  else
    assign menu_bg_start = section.settings.menu_bg_start | default: '#f4f3ee'
    assign menu_bg_end = section.settings.menu_bg_end | default: '#e9e7df'
    assign menu_opacity_pct = section.settings.menu_bg_opacity | default: 92
    assign menu_opacity = menu_opacity_pct | times: 1.0 | divided_by: 100.0
    assign menu_gradient_angle = section.settings.menu_gradient_angle | default: 180
    assign menu_blur_on = section.settings.menu_blur_background
    if menu_blur_on == nil
      assign menu_blur_on = true
    endif
    assign menu_blur_amount = section.settings.menu_blur_amount | default: 12
    assign menu_bg_start_a = menu_bg_start | color_modify: 'alpha', menu_opacity
    assign menu_bg_end_a = menu_bg_end | color_modify: 'alpha', menu_opacity
    assign menu_bg = 'linear-gradient(' | append: menu_gradient_angle | append: 'deg, ' | append: menu_bg_start_a | append: ', ' | append: menu_bg_end_a | append: ')'
    if menu_blur_on
      assign menu_blur_value = 'blur(' | append: menu_blur_amount | append: 'px)'
    else
      assign menu_blur_value = 'none'
    endif
  endif
-%}
<header
  class="j14-header{% if section.settings.transparent_home and template.name == 'index' %} j14-header--transparent{% endif %}{% if blur_enabled %} j14-header--blur{% endif %}{% if menu_match %} j14-header--menu-match{% endif %}{% if menu_blur_on %} j14-header--menu-blur{% endif %}"
  data-j14-header
  style="
    --j14-hdr-bg: {{ hdr_bg }};
    --j14-hdr-text: {{ text_color }};
    --j14-hdr-text-rgb: {{ text_rgb }};
    --j14-hdr-blur: {{ blur_value }};
    --j14-hdr-opacity: {{ opacity }};
    --j14-menu-bg: {{ menu_bg }};
    --j14-menu-blur: {{ menu_blur_value }};
  "
>
  <div class="j14-header__inner">
    <a href="{{ routes.root_url }}" class="j14-header__logo" aria-label="{{ shop.name | escape }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 360
          | image_tag: class: 'j14-header__logo-img', widths: '120, 240, 360', sizes: '120px', alt: shop.name
        }}
      {%- else -%}
        <span class="j14-header__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="j14-header__nav" id="j14-nav" aria-label="Main">
      <ul class="j14-header__list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign href = block.settings.url
            if block.settings.anchor_id != blank
              assign href = routes.root_url | append: '#' | append: block.settings.anchor_id
            endif
          -%}
          <li {{ block.shopify_attributes }}>
            <a class="j14-header__link" href="{{ href | default: routes.root_url }}">{{ block.settings.label | escape }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="j14-header__actions">
      <a class="j14-header__cart" href="{{ routes.cart_url }}" aria-label="{{ 'cart.general.title' | t }}">
        <svg class="j14-header__cart-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M6 7h12l-1.2 12.2a1.5 1.5 0 0 1-1.5 1.3H8.7a1.5 1.5 0 0 1-1.5-1.3L6 7Z"/>
          <path d="M9 9V6a3 3 0 1 1 6 0v3"/>
        </svg>
        <span class="j14-header__cart-count" data-j14-cart-count>{{ cart_count }}</span>
      </a>
      <button
        class="j14-header__toggle"
        type="button"
        aria-expanded="false"
        aria-controls="j14-nav"
        data-j14-menu-toggle
      >
        <span class="j14-header__toggle-bar"></span>
        <span class="j14-header__toggle-bar"></span>
        <span class="j14-visually-hidden">{{ section.settings.menu_label | default: 'Menu' }}</span>
      </button>
    </div>
  </div>
</header>

<script>
  (function () {
    var header = document.querySelector('[data-j14-header]');
    if (!header) return;
    var toggle = header.querySelector('[data-j14-menu-toggle]');
    if (toggle) {
      toggle.addEventListener('click', function () {
        var open = header.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        document.documentElement.classList.toggle('j14-menu-open', open);
      });
      header.querySelectorAll('.j14-header__link').forEach(function (link) {
        link.addEventListener('click', function () {
          header.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          document.documentElement.classList.remove('j14-menu-open');
        });
      });
    }
    var onScroll = function () {
      header.classList.toggle('is-scrolled', window.scrollY > 24);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

{% schema %}
{
  "name": "J14 Header",
  "tag": "header",
  "class": "j14-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "info": "Used when no logo image is set. Defaults to the store name."
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Mobile menu label",
      "default": "Menu"
    },
    {
      "type": "checkbox",
      "id": "transparent_home",
      "label": "Transparent over homepage intro",
      "default": true,
      "info": "Header starts clear on the homepage until you scroll or open the mobile menu."
    },
    {
      "type": "header",
      "content": "Sticky header bar"
    },
    {
      "type": "paragraph",
      "content": "Styles the fixed top nav bar on mobile and desktop."
    },
    {
      "type": "color",
      "id": "bg_start",
      "label": "Gradient start",
      "default": "#f4f3ee"
    },
    {
      "type": "color",
      "id": "bg_end",
      "label": "Gradient end",
      "default": "#e9e7df"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 15,
      "unit": "deg",
      "default": 180
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "label": "Background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 92
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & icon color",
      "default": "#111214"
    },
    {
      "type": "checkbox",
      "id": "blur_background",
      "label": "Blur background",
      "default": true,
      "info": "Applies backdrop blur behind the sticky header bar."
    },
    {
      "type": "range",
      "id": "blur_amount",
      "label": "Blur strength",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Mobile dropdown menu"
    },
    {
      "type": "paragraph",
      "content": "When matching is on, the open menu shares the header background so they read as one panel. Turn matching off to style the dropdown independently."
    },
    {
      "type": "checkbox",
      "id": "menu_match_header",
      "label": "Mobile menu matches header background",
      "default": true
    },
    {
      "type": "color",
      "id": "menu_bg_start",
      "label": "Menu gradient start",
      "default": "#f4f3ee",
      "visible_if": "{{ section.settings.menu_match_header == false }}"
    },
    {
      "type": "color",
      "id": "menu_bg_end",
      "label": "Menu gradient end",
      "default": "#e9e7df",
      "visible_if": "{{ section.settings.menu_match_header == false }}"
    },
    {
      "type": "range",
      "id": "menu_gradient_angle",
      "label": "Menu gradient angle",
      "min": 0,
      "max": 360,
      "step": 15,
      "unit": "deg",
      "default": 180,
      "visible_if": "{{ section.settings.menu_match_header == false }}"
    },
    {
      "type": "range",
      "id": "menu_bg_opacity",
      "label": "Menu background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 92,
      "visible_if": "{{ section.settings.menu_match_header == false }}"
    },
    {
      "type": "checkbox",
      "id": "menu_blur_background",
      "label": "Menu blur background",
      "default": true,
      "visible_if": "{{ section.settings.menu_match_header == false }}"
    },
    {
      "type": "range",
      "id": "menu_blur_amount",
      "label": "Menu blur strength",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12,
      "visible_if": "{{ section.settings.menu_match_header == false }}"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Homepage anchor ID",
          "info": "Overrides the link. E.g. colors, how, flavors, about."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
