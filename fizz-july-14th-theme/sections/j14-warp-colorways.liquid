{%- liquid
  assign source = section.settings.source | default: 'variants'
  assign bottle = section.settings.product | default: settings.bottle_product
  assign cta_label = section.settings.cta_label | default: 'Shop this color'
  assign demo_slugs = 'steel-navy,electric-blue,coral-orange,sage-green,charcoal-black,arctic-white' | split: ','
  assign section_height = section.settings.section_height | default: 100
  assign media_height = section.settings.media_height | default: 52

  assign product_items = blank
  if source == 'collection' and section.settings.collection != blank
    assign product_items = section.settings.collection.products
  elsif source == 'products' and section.settings.products.count > 0
    assign product_items = section.settings.products
  endif

  if product_items != blank
    assign init_item = product_items | first
    assign init_name = init_item.title
    assign init_price = init_item.price | money
    assign init_href = init_item.url
  elsif bottle != blank
    assign init_variant = bottle.variants.first
    assign init_name = init_variant.title
    assign init_price = init_variant.price | money
    assign init_href = bottle.url | append: '?variant=' | append: init_variant.id
  else
    assign init_name = 'Steel navy'
    assign init_price = ''
    assign init_href = routes.all_products_collection_url
  endif
-%}
{%- capture warp_slides -%}
  {%- if product_items != blank -%}
    {%- comment -%}
      Product modes (collection / manual list): one slide per product.
      Scene colors come from product metafields (custom.scene_*) with theme
      defaults; media resolves warp_media metafield > native media > gradient.
    {%- endcomment -%}
    {%- for item in product_items limit: 12 -%}
      {%- assign bg = item.metafields.custom.scene_bg | default: '#0f1a2e' -%}
      {%- assign bg_end = item.metafields.custom.scene_bg_end | default: '#26344f' -%}
      {%- assign btn = item.metafields.custom.scene_btn | default: '#c6f24e' -%}
      {%- assign text_color = item.metafields.custom.scene_text | default: '#f2efe7' -%}
      {%- assign swatch = item.metafields.custom.swatch_hex | default: bg_end -%}
      {%- assign btn_brightness = btn | color_brightness -%}
      {%- if btn_brightness > 160 -%}
        {%- assign btn_text = '#080a0d' -%}
      {%- else -%}
        {%- assign btn_text = '#f2efe7' -%}
      {%- endif -%}
      {%- assign media_field = item.metafields.custom.warp_media -%}
      <li
        class="j14-warp__slide{% if forloop.first %} is-active{% endif %}"
        data-j14-warp-slide
        data-index="{{ forloop.index0 }}"
        data-bg="{{ bg }}"
        data-bg-end="{{ bg_end }}"
        data-btn="{{ btn }}"
        data-btn-text="{{ btn_text }}"
        data-text="{{ text_color }}"
        data-swatch="{{ swatch }}"
        data-name="{{ item.title | escape }}"
        data-price="{{ item.price | money }}"
        data-href="{{ item.url }}"
      >
        <div class="j14-warp__panel" style="--panel-bg: {{ swatch }}; --panel-bg-end: {{ bg_end }};">
          {%- if media_field != blank and media_field.value.media_type == 'video' -%}
            {{ media_field.value | video_tag: class: 'j14-warp__video', loop: true, muted: true, controls: false, preload: 'metadata' }}
          {%- elsif media_field != blank -%}
            {{ media_field.value | image_url: width: 900 | image_tag: class: 'j14-warp__photo', loading: 'lazy', sizes: '(min-width: 750px) 33vw, 88vw', widths: '360, 540, 720, 900', alt: item.title }}
          {%- elsif item.featured_media.media_type == 'video' -%}
            {{ item.featured_media | video_tag: class: 'j14-warp__video', loop: true, muted: true, controls: false, preload: 'metadata' }}
          {%- elsif item.featured_image -%}
            {{ item.featured_image | image_url: width: 900 | image_tag: class: 'j14-warp__photo', loading: 'lazy', sizes: '(min-width: 750px) 33vw, 88vw', widths: '360, 540, 720, 900', alt: item.title }}
          {%- endif -%}
        </div>
      </li>
    {%- endfor -%}
  {%- elsif bottle != blank -%}
    {%- comment -%}
      Variants mode (default): one slide per variant of the bottle product.
    {%- endcomment -%}
    {%- for variant in bottle.variants -%}
      {%- capture slug -%}{% render 'j14-color-slug', variant: variant %}{%- endcapture -%}
      {%- assign slug = slug | strip -%}
      {%- capture scene -%}{% render 'j14-colorway-scene', slug: slug, variant: variant %}{%- endcapture -%}
      {%- assign scene_parts = scene | strip | split: '|' -%}
      {%- assign bg = scene_parts[0] -%}
      {%- assign bg_end = scene_parts[1] -%}
      {%- assign btn = scene_parts[2] -%}
      {%- assign text_color = scene_parts[3] -%}
      {%- assign swatch = scene_parts[4] -%}
      {%- assign btn_text = scene_parts[5] -%}
      {%- assign override_image = blank -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.slug == slug -%}
          {%- if block.settings.bg != blank %}{% assign bg = block.settings.bg %}{% endif -%}
          {%- if block.settings.bg_end != blank %}{% assign bg_end = block.settings.bg_end %}{% endif -%}
          {%- if block.settings.btn != blank %}{% assign btn = block.settings.btn %}{% endif -%}
          {%- if block.settings.text != blank %}{% assign text_color = block.settings.text %}{% endif -%}
          {%- if block.settings.image != blank %}{% assign override_image = block.settings.image %}{% endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign media_field = variant.metafields.custom.warp_media -%}
      <li
        class="j14-warp__slide{% if forloop.first %} is-active{% endif %}"
        data-j14-warp-slide
        data-index="{{ forloop.index0 }}"
        data-bg="{{ bg }}"
        data-bg-end="{{ bg_end }}"
        data-btn="{{ btn }}"
        data-btn-text="{{ btn_text }}"
        data-text="{{ text_color }}"
        data-swatch="{{ swatch }}"
        data-name="{{ variant.title | escape }}"
        data-price="{{ variant.price | money }}"
        data-href="{{ bottle.url }}?variant={{ variant.id }}"
      >
        <div class="j14-warp__panel" style="--panel-bg: {{ swatch }}; --panel-bg-end: {{ bg_end }};">
          {%- if media_field != blank and media_field.value.media_type == 'video' -%}
            {{ media_field.value | video_tag: class: 'j14-warp__video', loop: true, muted: true, controls: false, preload: 'metadata' }}
          {%- elsif media_field != blank -%}
            {{ media_field.value | image_url: width: 900 | image_tag: class: 'j14-warp__photo', loading: 'lazy', sizes: '(min-width: 750px) 33vw, 88vw', widths: '360, 540, 720, 900', alt: variant.title }}
          {%- elsif override_image != blank -%}
            {{ override_image | image_url: width: 900 | image_tag: class: 'j14-warp__photo', loading: 'lazy', sizes: '(min-width: 750px) 33vw, 88vw', widths: '360, 540, 720, 900', alt: variant.title }}
          {%- elsif variant.featured_image -%}
            {{ variant.featured_image | image_url: width: 900 | image_tag: class: 'j14-warp__photo', loading: 'lazy', sizes: '(min-width: 750px) 33vw, 88vw', widths: '360, 540, 720, 900', alt: variant.title }}
          {%- else -%}
            <img
              src="{{ 'fizz-bottle-product-' | append: slug | append: '.png' | asset_url }}"
              class="j14-warp__img"
              loading="lazy"
              width="504"
              height="1400"
              alt="{{ variant.title | escape }}"
            >
          {%- endif -%}
        </div>
      </li>
    {%- endfor -%}
  {%- else -%}
    {%- for slug in demo_slugs -%}
      {%- capture scene -%}{% render 'j14-colorway-scene', slug: slug %}{%- endcapture -%}
      {%- assign scene_parts = scene | strip | split: '|' -%}
      <li
        class="j14-warp__slide{% if forloop.first %} is-active{% endif %}"
        data-j14-warp-slide
        data-index="{{ forloop.index0 }}"
        data-bg="{{ scene_parts[0] }}"
        data-bg-end="{{ scene_parts[1] }}"
        data-btn="{{ scene_parts[2] }}"
        data-btn-text="{{ scene_parts[5] }}"
        data-text="{{ scene_parts[3] }}"
        data-swatch="{{ scene_parts[4] }}"
        data-name="{{ slug | replace: '-', ' ' | capitalize | escape }}"
        data-price=""
        data-href="{{ routes.all_products_collection_url }}"
      >
        <div class="j14-warp__panel" style="--panel-bg: {{ scene_parts[4] }}; --panel-bg-end: {{ scene_parts[1] }};">
          <img
            src="{{ 'fizz-bottle-product-' | append: slug | append: '.png' | asset_url }}"
            class="j14-warp__img"
            loading="lazy"
            width="504"
            height="1400"
            alt="{{ slug | replace: '-', ' ' | capitalize | escape }}"
          >
        </div>
      </li>
    {%- endfor -%}
  {%- endif -%}
{%- endcapture -%}

<section
  class="j14-warp{% unless section.settings.sync_scene %} j14-warp--static{% endunless %}"
  id="{{ section.settings.anchor_id | default: 'colors' }}"
  data-j14-warp
  data-sync-scene="{{ section.settings.sync_scene }}"
  style="--ways-section-height: {{ section_height }}vh; --ways-media-height: min({{ media_height }}vh, 640px);"
>
  <div class="j14-warp__head">
    {%- if section.settings.eyebrow != blank -%}
      <p class="j14-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="j14-heading j14-warp__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
  </div>

  <div class="j14-warp__stage">
    {%- comment -%} Wave overlays recreate the Webflow warp silhouette (clip illusion). {%- endcomment -%}
    <svg
      class="j14-warp__wave j14-warp__wave--top"
      viewBox="0 0 804 50.167"
      preserveAspectRatio="none"
      aria-hidden="true"
      focusable="false"
    >
      <path
        fill="currentColor"
        d="M804,0 v16.671 c0,0 -204.974,33.496 -401.995,33.496 C204.974,50.167 0,16.671 0,16.671 V0 H804z"
      ></path>
    </svg>
    <svg
      class="j14-warp__wave j14-warp__wave--bottom"
      viewBox="0 0 804 50.167"
      preserveAspectRatio="none"
      aria-hidden="true"
      focusable="false"
    >
      <path
        fill="currentColor"
        d="M804,0 v16.671 c0,0 -204.974,33.496 -401.995,33.496 C204.974,50.167 0,16.671 0,16.671 V0 H804z"
      ></path>
    </svg>

    <div class="j14-warp__viewport">
      <ul
        class="j14-warp__track"
        data-j14-warp-track
        tabindex="0"
        aria-label="{{ section.settings.heading | default: 'Bottle colors' | escape }}"
      >
        {{ warp_slides }}
      </ul>
    </div>
  </div>

  <div class="j14-warp__controls">
    <button type="button" class="j14-warp__arrow" data-j14-warp-prev aria-label="{{ 'general.accessibility.previous' | t }}">
      &larr;
    </button>
    <div class="j14-warp__dots" data-j14-warp-dots role="tablist"></div>
    <button type="button" class="j14-warp__arrow" data-j14-warp-next aria-label="{{ 'general.accessibility.next' | t }}">
      &rarr;
    </button>
  </div>

  <div class="j14-warp__caption" data-j14-warp-caption>
    <h3 class="j14-warp__name" data-j14-warp-name>{{ init_name | escape }}</h3>
    {%- if init_price != blank -%}
      <p class="j14-warp__price" data-j14-warp-price>{{ init_price }}</p>
    {%- else -%}
      <p class="j14-warp__price" data-j14-warp-price hidden></p>
    {%- endif -%}
    <a class="j14-btn j14-warp__cta" data-j14-warp-cta href="{{ init_href }}">{{ cta_label | escape }}</a>
  </div>
</section>

{% schema %}
{
  "name": "J14 Warp Colorways",
  "tag": "section",
  "class": "j14-warp-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The bottle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick your color"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "colors"
    },
    {
      "type": "header",
      "content": "Slides source"
    },
    {
      "type": "select",
      "id": "source",
      "label": "Show slides from",
      "options": [
        { "value": "variants", "label": "Product variants" },
        { "value": "collection", "label": "Collection" },
        { "value": "products", "label": "Manual product list" }
      ],
      "default": "variants",
      "info": "Product variants: one slide per variant of the bottle product. Collection or manual list: one slide per product (up to 12). Slide media resolves the custom.warp_media metafield (image or video) first, then native product media."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Bottle product",
      "info": "Used by the Product variants source. Falls back to the theme's default bottle product, then to demo colorways."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used by the Collection source."
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "limit": 12,
      "info": "Used by the Manual product list source."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop this color"
    },
    {
      "type": "checkbox",
      "id": "sync_scene",
      "label": "Sync background with active color",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "info": "Minimum height of the section as a percentage of the viewport.",
      "min": 70,
      "max": 120,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "media_height",
      "label": "Media panel height",
      "info": "How tall slide media panels render inside the carousel.",
      "min": 30,
      "max": 70,
      "step": 2,
      "unit": "vh",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "colorway",
      "name": "Colorway override",
      "settings": [
        {
          "type": "select",
          "id": "slug",
          "label": "Colorway",
          "options": [
            { "value": "steel-navy", "label": "Steel Navy" },
            { "value": "electric-blue", "label": "Electric Blue" },
            { "value": "coral-orange", "label": "Coral Orange" },
            { "value": "sage-green", "label": "Sage Green" },
            { "value": "charcoal-black", "label": "Charcoal Black" },
            { "value": "arctic-white", "label": "Arctic White" }
          ],
          "default": "steel-navy"
        },
        {
          "type": "color",
          "id": "bg",
          "label": "Background start"
        },
        {
          "type": "color",
          "id": "bg_end",
          "label": "Background end"
        },
        {
          "type": "color",
          "id": "btn",
          "label": "Button color"
        },
        {
          "type": "color",
          "id": "text",
          "label": "Text color"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bottle image override"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "J14 Warp Colorways"
    }
  ],
  "enabled_on": {
    "templates": ["index", "page", "product", "collection"]
  }
}
{% endschema %}
