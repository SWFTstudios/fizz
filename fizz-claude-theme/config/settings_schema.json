[
  {
    "name": "theme_info",
    "theme_name": "Fizz Claude",
    "theme_author": "Fizz Hydration",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/",
    "theme_support_url": "https://github.com/"
  },
  {
    "name": "Brand colors",
    "settings": [
      {
        "type": "paragraph",
        "content": "Deprecated — use Colorway design below. Legacy values kept for reference only."
      },
      {
        "type": "color",
        "id": "fizz_accent_color",
        "label": "Accent (lime)",
        "default": "#c6f24e"
      },
      {
        "type": "color",
        "id": "fizz_ink_color",
        "label": "Ink (background)",
        "default": "#080a0d"
      },
      {
        "type": "color",
        "id": "fizz_paper_color",
        "label": "Paper (light sections)",
        "default": "#f2efe7"
      }
    ]
  },
  {
    "name": "Colorway design",
    "settings": [
      {
        "type": "header",
        "content": "Preset palette"
      },
      {
        "type": "select",
        "id": "colorway_preset",
        "label": "Colorway preset",
        "options": [
          { "value": "lime_fizz", "label": "Lime Fizz" },
          { "value": "steel_navy", "label": "Steel Navy" },
          { "value": "citrus_burst", "label": "Citrus Burst" },
          { "value": "berry_night", "label": "Berry Night" },
          { "value": "electric_pool", "label": "Electric Pool" },
          { "value": "arctic_light", "label": "Arctic Light" }
        ],
        "default": "lime_fizz"
      },
      {
        "type": "paragraph",
        "content": "Lime Fizz: high-contrast brand default. Steel Navy: cool monochromatic. Citrus Burst: warm analogous. Berry Night: purple complement. Electric Pool: triadic blue-forward. Arctic Light: inverted light-surface mode (select only — not a Theme style; Shopify allows max 5 native presets)."
      },
      {
        "type": "paragraph",
        "content": "Storefront colors apply from the preset select on save. For matching color pickers in this panel, switch Theme style (top of theme editor) to Lime Fizz, Steel Navy, etc. Enable Custom colors to fine-tune individual tokens."
      },
      {
        "type": "checkbox",
        "id": "colorway_custom_enabled",
        "label": "Use custom colors instead of preset",
        "default": false
      },
      {
        "type": "header",
        "content": "Custom brand colors"
      },
      {
        "type": "color",
        "id": "colorway_accent",
        "label": "Accent",
        "default": "#c6f24e",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_ink",
        "label": "Ink",
        "default": "#080a0d",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_paper",
        "label": "Paper",
        "default": "#f2efe7",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_accent_contrast",
        "label": "Accent contrast (text on buttons)",
        "info": "Leave blank for auto (ink on light accent, paper on dark)",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_muted_text",
        "label": "Muted text",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_surface_elevated",
        "label": "Elevated surface (cards, PDP stage)",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_border",
        "label": "Border / divider",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "colorway_link_hover",
        "label": "Link hover",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "header",
        "content": "Section surfaces"
      },
      {
        "type": "checkbox",
        "id": "colorway_hero_use_global",
        "label": "Hero — use global colorway",
        "default": true
      },
      {
        "type": "color",
        "id": "colorway_hero_bg",
        "label": "Hero background",
        "default": "#080a0d",
        "visible_if": "{{ settings.colorway_hero_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_hero_text",
        "label": "Hero text",
        "default": "#f2efe7",
        "visible_if": "{{ settings.colorway_hero_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_hero_accent",
        "label": "Hero accent",
        "default": "#c6f24e",
        "visible_if": "{{ settings.colorway_hero_use_global == false }}"
      },
      {
        "type": "checkbox",
        "id": "colorway_statement_use_global",
        "label": "Statement — use global colorway",
        "default": true
      },
      {
        "type": "color",
        "id": "colorway_statement_bg",
        "label": "Statement background",
        "default": "#f2efe7",
        "visible_if": "{{ settings.colorway_statement_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_statement_text",
        "label": "Statement text",
        "default": "#080a0d",
        "visible_if": "{{ settings.colorway_statement_use_global == false }}"
      },
      {
        "type": "checkbox",
        "id": "colorway_how_use_global",
        "label": "How it works — use global colorway",
        "default": true
      },
      {
        "type": "color",
        "id": "colorway_how_bg",
        "label": "How background",
        "default": "#080a0d",
        "visible_if": "{{ settings.colorway_how_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_how_text",
        "label": "How text",
        "default": "#f2efe7",
        "visible_if": "{{ settings.colorway_how_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_how_stroke",
        "label": "How step stroke",
        "default": "#c6f24e",
        "visible_if": "{{ settings.colorway_how_use_global == false }}"
      },
      {
        "type": "checkbox",
        "id": "colorway_footer_use_global",
        "label": "Footer — use global colorway",
        "default": true
      },
      {
        "type": "color",
        "id": "colorway_footer_bg",
        "label": "Footer background",
        "default": "#080a0d",
        "visible_if": "{{ settings.colorway_footer_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_footer_text",
        "label": "Footer text",
        "default": "#f2efe7",
        "visible_if": "{{ settings.colorway_footer_use_global == false }}"
      },
      {
        "type": "color",
        "id": "colorway_footer_stroke",
        "label": "Footer outline stroke",
        "default": "#c6f24e",
        "visible_if": "{{ settings.colorway_footer_use_global == false }}"
      },
      {
        "type": "header",
        "content": "Typography"
      },
      {
        "type": "select",
        "id": "font_display",
        "label": "Display font (hero, footer)",
        "options": [
          { "value": "anton", "label": "Anton" },
          { "value": "system", "label": "System sans" }
        ],
        "default": "anton"
      },
      {
        "type": "select",
        "id": "font_body",
        "label": "Body font",
        "options": [
          { "value": "archivo", "label": "Archivo" },
          { "value": "system", "label": "System sans" }
        ],
        "default": "archivo"
      },
      {
        "type": "select",
        "id": "font_accent",
        "label": "Accent italic font",
        "options": [
          { "value": "bodoni", "label": "Bodoni Moda" },
          { "value": "system", "label": "Georgia / serif" }
        ],
        "default": "bodoni"
      },
      {
        "type": "select",
        "id": "font_label",
        "label": "Label / mono font",
        "options": [
          { "value": "jetbrains", "label": "JetBrains Mono" },
          { "value": "system", "label": "System mono" }
        ],
        "default": "jetbrains"
      },
      {
        "type": "range",
        "id": "typo_hero_scale",
        "min": 80,
        "max": 120,
        "step": 5,
        "unit": "%",
        "label": "Hero display scale",
        "default": 100
      },
      {
        "type": "range",
        "id": "typo_body_size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "label": "Body size base",
        "default": 16
      },
      {
        "type": "range",
        "id": "typo_label_spacing",
        "min": 6,
        "max": 30,
        "step": 2,
        "unit": "em",
        "label": "Label letter-spacing (×0.01em)",
        "default": 16,
        "info": "16 = 0.16em"
      },
      {
        "type": "checkbox",
        "id": "typo_nav_uppercase",
        "label": "Uppercase nav links",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "typo_accent_italic",
        "label": "Italic accent headings",
        "default": true
      },
      {
        "type": "header",
        "content": "Buttons and CTAs"
      },
      {
        "type": "color",
        "id": "btn_primary_bg",
        "label": "Primary button background",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "btn_primary_text",
        "label": "Primary button text",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "btn_outline_border",
        "label": "Outline button border",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "color",
        "id": "btn_outline_text",
        "label": "Outline button text",
        "visible_if": "{{ settings.colorway_custom_enabled }}"
      },
      {
        "type": "select",
        "id": "btn_radius",
        "label": "Button border radius",
        "options": [
          { "value": "pill", "label": "Pill" },
          { "value": "rounded", "label": "Rounded (12px)" }
        ],
        "default": "pill"
      },
      {
        "type": "range",
        "id": "btn_hover_scale",
        "min": 100,
        "max": 110,
        "step": 1,
        "unit": "%",
        "label": "CTA hover scale",
        "default": 105
      }
    ]
  },
  {
    "name": "Products",
    "settings": [
      {
        "type": "product",
        "id": "fizz_bottle_product",
        "label": "Bottle product (nav CTA + colorways default)"
      }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      {
        "type": "header",
        "content": "Logo"
      },
      {
        "type": "image_picker",
        "id": "nav_logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "nav_logo_max_height",
        "min": 16,
        "max": 80,
        "step": 2,
        "unit": "px",
        "label": "Logo max height",
        "default": 24
      },
      {
        "type": "range",
        "id": "nav_logo_max_width",
        "min": 60,
        "max": 320,
        "step": 4,
        "unit": "px",
        "label": "Logo max width",
        "default": 160
      },
      {
        "type": "checkbox",
        "id": "nav_logo_invert",
        "label": "Invert logo colors",
        "default": true,
        "info": "Helps light logos read on dark hero sections"
      },
      {
        "type": "header",
        "content": "Glass background"
      },
      {
        "type": "checkbox",
        "id": "nav_glass_enabled",
        "label": "Enable glassmorphic background",
        "default": true
      },
      {
        "type": "color",
        "id": "nav_tint_color",
        "label": "Tint color",
        "default": "#080a0d"
      },
      {
        "type": "range",
        "id": "nav_tint_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Tint opacity",
        "default": 55
      },
      {
        "type": "range",
        "id": "nav_blur",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Blur amount",
        "default": 16
      },
      {
        "type": "range",
        "id": "nav_border_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Bottom border opacity",
        "default": 15
      },
      {
        "type": "checkbox",
        "id": "nav_gradient_enabled",
        "label": "Enable gradient overlay",
        "default": false
      },
      {
        "type": "color",
        "id": "nav_gradient_start",
        "label": "Gradient start",
        "default": "#080a0d"
      },
      {
        "type": "color",
        "id": "nav_gradient_end",
        "label": "Gradient end",
        "default": "#1a2230"
      },
      {
        "type": "range",
        "id": "nav_gradient_angle",
        "min": 0,
        "max": 360,
        "step": 15,
        "unit": "deg",
        "label": "Gradient angle",
        "default": 180
      },
      {
        "type": "header",
        "content": "Colorway sync"
      },
      {
        "type": "checkbox",
        "id": "nav_sync_colorway_tint",
        "label": "Sync nav tint to colorway ink",
        "default": false
      },
      {
        "type": "header",
        "content": "Blend & effects"
      },
      {
        "type": "select",
        "id": "nav_blend_mode",
        "label": "Mix blend mode",
        "options": [
          { "value": "difference", "label": "Difference" },
          { "value": "normal", "label": "Normal" },
          { "value": "unset", "label": "None" }
        ],
        "default": "difference",
        "info": "Use Normal or None when glass background is enabled"
      }
    ]
  },
  {
    "name": "Bubble animation",
    "settings": [
      {
        "type": "paragraph",
        "content": "Ambient rising bubbles in hero, how-it-works, footer, and PDP stage. See README for per-section overrides."
      },
      {
        "type": "checkbox",
        "id": "bubble_enabled",
        "label": "Enable ambient bubbles",
        "default": true
      },
      {
        "type": "select",
        "id": "bubble_style",
        "label": "Bubble style",
        "options": [
          { "value": "ring", "label": "Ring — canvas outline only (lightweight)" },
          { "value": "glass", "label": "Glass — modern specular bubbles (recommended)" },
          { "value": "foam", "label": "Foam — dense micro-fizz" },
          { "value": "bold", "label": "Bold — larger bubbles, stronger fill" }
        ],
        "default": "glass"
      },
      {
        "type": "range",
        "id": "bubble_peak_opacity",
        "min": 50,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "Animation peak opacity",
        "default": 88
      },
      {
        "type": "range",
        "id": "bubble_size_scale",
        "min": 75,
        "max": 200,
        "step": 5,
        "unit": "%",
        "label": "Bubble size",
        "default": 115
      },
      {
        "type": "range",
        "id": "bubble_count_scale",
        "min": 50,
        "max": 200,
        "step": 5,
        "unit": "%",
        "label": "Bubble density",
        "default": 100
      },
      {
        "type": "header",
        "content": "Section bubble color strength"
      },
      {
        "type": "range",
        "id": "bubble_hero_alpha",
        "min": 10,
        "max": 80,
        "step": 1,
        "unit": "%",
        "label": "Hero & PDP alpha",
        "default": 45
      },
      {
        "type": "range",
        "id": "bubble_how_alpha",
        "min": 10,
        "max": 80,
        "step": 1,
        "unit": "%",
        "label": "How it works alpha",
        "default": 55
      },
      {
        "type": "range",
        "id": "bubble_footer_alpha",
        "min": 10,
        "max": 80,
        "step": 1,
        "unit": "%",
        "label": "Footer alpha",
        "default": 38
      },
      {
        "type": "checkbox",
        "id": "bubble_wobble",
        "label": "Subtle horizontal wobble",
        "default": false
      },
      {
        "type": "header",
        "content": "Page transitions"
      },
      {
        "type": "paragraph",
        "content": "Brand overlay on internal navigation. Melt uses merging micro-bubbles; Classic keeps the original liquid-wave slabs."
      },
      {
        "type": "select",
        "id": "page_transition_style",
        "label": "Transition style",
        "options": [
          { "value": "melt", "label": "Melt — carbonation metaball (recommended)" },
          { "value": "classic", "label": "Classic — liquid wave slabs" }
        ],
        "default": "melt"
      },
      {
        "type": "range",
        "id": "page_transition_intensity",
        "min": 50,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Transition intensity",
        "default": 100,
        "info": "Blob count and size during melt transitions."
      },
      {
        "type": "range",
        "id": "page_transition_duration_scale",
        "min": 50,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Transition duration",
        "default": 100
      }
    ]
  }
]
