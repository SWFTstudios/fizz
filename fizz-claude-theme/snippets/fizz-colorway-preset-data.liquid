{% comment %}
  Outputs preset token string for fizz-theme-tokens.liquid
  Format: accent|ink|paper|hero_bg|hero_text|hero_accent|statement_bg|statement_text|how_bg|how_text|how_stroke|footer_bg|footer_text|footer_stroke
  Keep in sync with design/colorway-presets/presets.json
{% endcomment %}
{% liquid
  assign p = preset | default: 'lime_fizz'
  assign accent = '#c6f24e'
  assign ink = '#080a0d'
  assign paper = '#f2efe7'
  assign hero_bg = '#080a0d'
  assign hero_text = '#f2efe7'
  assign hero_accent = '#c6f24e'
  assign statement_bg = '#f2efe7'
  assign statement_text = '#080a0d'
  assign how_bg = '#080a0d'
  assign how_text = '#f2efe7'
  assign how_stroke = '#c6f24e'
  assign footer_bg = '#080a0d'
  assign footer_text = '#f2efe7'
  assign footer_stroke = '#c6f24e'

  case p
    when 'steel_navy'
      assign accent = '#6b9fd4'
      assign ink = '#0f1a2e'
      assign paper = '#e8edf5'
      assign hero_bg = '#0f1a2e'
      assign hero_text = '#e8edf5'
      assign hero_accent = '#6b9fd4'
      assign statement_bg = '#e8edf5'
      assign statement_text = '#0f1a2e'
      assign how_bg = '#0f1a2e'
      assign how_text = '#e8edf5'
      assign how_stroke = '#6b9fd4'
      assign footer_bg = '#0f1a2e'
      assign footer_text = '#e8edf5'
      assign footer_stroke = '#6b9fd4'
    when 'citrus_burst'
      assign accent = '#f07a2e'
      assign ink = '#1a0f08'
      assign paper = '#f5ebe0'
      assign hero_bg = '#1a0f08'
      assign hero_text = '#f5ebe0'
      assign hero_accent = '#f07a2e'
      assign statement_bg = '#f5ebe0'
      assign statement_text = '#1a0f08'
      assign how_bg = '#1a0f08'
      assign how_text = '#f5ebe0'
      assign how_stroke = '#f07a2e'
      assign footer_bg = '#1a0f08'
      assign footer_text = '#f5ebe0'
      assign footer_stroke = '#f07a2e'
    when 'berry_night'
      assign accent = '#c86bff'
      assign ink = '#120818'
      assign paper = '#f0e8f5'
      assign hero_bg = '#120818'
      assign hero_text = '#f0e8f5'
      assign hero_accent = '#c86bff'
      assign statement_bg = '#f0e8f5'
      assign statement_text = '#120818'
      assign how_bg = '#120818'
      assign how_text = '#f0e8f5'
      assign how_stroke = '#c86bff'
      assign footer_bg = '#120818'
      assign footer_text = '#f0e8f5'
      assign footer_stroke = '#c86bff'
    when 'electric_pool'
      assign accent = '#2f6fd6'
      assign ink = '#061018'
      assign paper = '#e6f0fa'
      assign hero_bg = '#061018'
      assign hero_text = '#e6f0fa'
      assign hero_accent = '#2f6fd6'
      assign statement_bg = '#e6f0fa'
      assign statement_text = '#061018'
      assign how_bg = '#061018'
      assign how_text = '#e6f0fa'
      assign how_stroke = '#2f6fd6'
      assign footer_bg = '#061018'
      assign footer_text = '#e6f0fa'
      assign footer_stroke = '#2f6fd6'
    when 'arctic_light'
      assign accent = '#9ed12f'
      assign ink = '#f2efe7'
      assign paper = '#080a0d'
      assign hero_bg = '#f2efe7'
      assign hero_text = '#080a0d'
      assign hero_accent = '#9ed12f'
      assign statement_bg = '#080a0d'
      assign statement_text = '#f2efe7'
      assign how_bg = '#f2efe7'
      assign how_text = '#080a0d'
      assign how_stroke = '#9ed12f'
      assign footer_bg = '#080a0d'
      assign footer_text = '#f2efe7'
      assign footer_stroke = '#9ed12f'
  endcase
-%}{{ accent }}|{{ ink }}|{{ paper }}|{{ hero_bg }}|{{ hero_text }}|{{ hero_accent }}|{{ statement_bg }}|{{ statement_text }}|{{ how_bg }}|{{ how_text }}|{{ how_stroke }}|{{ footer_bg }}|{{ footer_text }}|{{ footer_stroke }}
