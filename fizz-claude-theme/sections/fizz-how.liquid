<div class="how" id="how" data-screen-label="How it works" style="background:var(--how-bg);color:var(--how-text)">
  <div class="howstick">
    <p class="anton howbig">{{ section.settings.title }}</p>
    {% render 'fizz-bubbles',
      settings: section.settings,
      color_var: 'var(--how-bubble-color)',
      seed: 23,
      rise: 800,
      default_count: 12
    %}
    {% if section.settings.bottle_image != blank %}
      <img class="botimg" src="{{ section.settings.bottle_image | image_url: width: 500 }}" alt="" loading="lazy" width="170">
    {% else %}
      <div class="botwrap">
        <div class="bcap"></div><div class="bneck"></div>
        <div class="bot" style="background:{{ section.settings.bottle_color }}">
          <img src="{{ 'fizz-logo.avif' | asset_url }}" class="blogo" alt="" width="48" height="48">
        </div>
      </div>
    {% endif %}
  </div>
  <div>
    {% for block in section.blocks %}
      <div class="step rv" {{ block.shopify_attributes }}>
        <p class="anton stepnum">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</p>
        <p class="steptitle">{{ block.settings.title }}</p>
        <p class="stepbody">{{ block.settings.body }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    { "type": "text", "id": "title", "label": "Background rotated title", "default": "How it works" },
    { "type": "image_picker", "id": "bottle_image", "label": "Bottle photo (overrides CSS bottle)" },
    { "type": "color", "id": "bottle_color", "label": "Fallback bottle color", "default": "#1d2a44" },

    { "type": "header", "content": "Bubbles" },
    {
      "type": "checkbox",
      "id": "bubbles_enabled",
      "label": "Enable bubble animation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "bubble_use_theme",
      "label": "Use theme bubble defaults",
      "default": true,
      "info": "Turn off to set count, size, style, and color for this section only.",
      "visible_if": "{{ section.settings.bubbles_enabled }}"
    },
    {
      "type": "range",
      "id": "bubble_count",
      "label": "Ambient bubble count",
      "min": 4,
      "max": 40,
      "step": 1,
      "default": 12,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "range",
      "id": "bubble_size_scale",
      "label": "Bubble size",
      "min": 50,
      "max": 200,
      "step": 5,
      "unit": "%",
      "default": 115,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "select",
      "id": "bubble_style",
      "label": "Bubble style",
      "default": "glass",
      "options": [
        { "value": "ring", "label": "Ring" },
        { "value": "glass", "label": "Glass" },
        { "value": "bold", "label": "Bold" }
      ],
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "color",
      "id": "bubble_color",
      "label": "Bubble color",
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "range",
      "id": "bubble_peak_opacity",
      "label": "Bubble opacity",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 88,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "checkbox",
      "id": "bubble_wobble",
      "label": "Wobble drift",
      "default": false,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_use_theme == false }}"
    },
    {
      "type": "select",
      "id": "bubble_interaction",
      "label": "User interaction",
      "default": "tap",
      "options": [
        { "value": "off", "label": "Off" },
        { "value": "tap", "label": "Tap area" },
        { "value": "button", "label": "Generator button" },
        { "value": "both", "label": "Tap area + button" }
      ],
      "visible_if": "{{ section.settings.bubbles_enabled }}"
    },
    {
      "type": "range",
      "id": "bubble_burst_count",
      "label": "Bubbles per tap",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 10,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction != 'off' }}"
    },
    {
      "type": "range",
      "id": "bubble_max_particles",
      "label": "Max particles",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 48,
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction != 'off' }}"
    },
    {
      "type": "text",
      "id": "bubble_button_label",
      "label": "Generator button label",
      "default": "Pop bubbles",
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction == 'button' or section.settings.bubbles_enabled and section.settings.bubble_interaction == 'both' }}"
    },
    {
      "type": "select",
      "id": "bubble_button_position",
      "label": "Generator button position",
      "default": "bottom-left",
      "options": [
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "top-right", "label": "Top right" }
      ],
      "visible_if": "{{ section.settings.bubbles_enabled and section.settings.bubble_interaction == 'button' or section.settings.bubbles_enabled and section.settings.bubble_interaction == 'both' }}"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Fill it cold" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Water, iced tea, juice — anything cold." }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Fill it cold", "body": "Water, iced tea, juice — anything cold. Double-wall vacuum steel keeps 24 ounces ice-cold from first light to last set." } },
        { "type": "step", "settings": { "title": "Twist to fizz", "body": "A recyclable CO₂ pod lives in the cap. One twist carbonates in eight seconds — dial it from gentle spritz to full bite. 60 fizzes per pod." } },
        { "type": "step", "settings": { "title": "Drop a flavor", "body": "Real fruit, zero sugar, added electrolytes. Citrus or berry. Healthy stopped being flavorless the day we bottled it." } }
      ]
    }
  ]
}
{% endschema %}
