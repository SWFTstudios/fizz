<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="fizz-html bubble-style-{{ settings.bubble_style | default: 'glass' }}{% unless settings.bubble_enabled %} bubble-disabled{% endunless %}{% if settings.bubble_wobble %} bubble-wobble{% endif %}" data-bubble-enabled="{% if settings.bubble_enabled %}true{% else %}false{% endif %}" data-transition-style="{{ settings.page_transition_style | default: 'melt' }}" data-transition-intensity="{{ settings.page_transition_intensity | default: 100 }}" data-transition-duration-scale="{{ settings.page_transition_duration_scale | default: 100 }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    <link rel="canonical" href="{{ canonical_url }}">
    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {{ 'fizz-fonts.css' | asset_url | stylesheet_tag }}
    {{ 'fizz-base.css' | asset_url | stylesheet_tag }}
    {{ 'fizz-cart-drawer.css' | asset_url | stylesheet_tag }}
    {{ 'fizz-search.css' | asset_url | stylesheet_tag }}
    {{ 'fizz-nav.css' | asset_url | stylesheet_tag }}
    {% render 'fizz-theme-tokens' %}
  </head>

  <body class="fizz overflow-x-hidden">
    {% sections 'header-group' %}

    <main id="main-content">
      {{ content_for_layout }}
    </main>

    <div class="grain" aria-hidden="true"></div>
    <script src="{{ 'fizz-nav.js' | asset_url }}" defer></script>
    <script src="{{ 'fizz-cart-drawer.js' | asset_url }}" defer></script>
    <script src="{{ 'fizz-search.js' | asset_url }}" defer></script>
    <script src="{{ 'fizz.js' | asset_url }}" defer></script>
    <script src="{{ 'fizz-page-transition.js' | asset_url }}" defer></script>
  </body>
</html>
